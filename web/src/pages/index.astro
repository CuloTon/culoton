---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import NewsCard from '../components/NewsCard.astro';
import FeaturedToken from '../components/FeaturedToken.astro';
import { UI } from '../i18n/strings';

const locale = 'en' as const;
const t = UI[locale];

const allNews = await getCollection('news_en');
const sorted = allNews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latest = sorted.slice(0, 24);

function stripLocaleFromId(id: string): string {
  return id.replace(/^en\//, '').replace(/\.md$/, '');
}
---

<Layout
  locale={locale}
  pathWithoutLocale="/"
  title={t.site_title}
  description={t.site_description}
>
  <div class="container">
    <section class="hero-banner">
      <div>
        <span class="badge">{t.hero_badge}</span>
        <h1 set:html={t.hero_headline_html} />
        <p>{t.hero_blurb}</p>
      </div>
    </section>

    <div class="section-title">
      <h2>{t.latest_news}</h2>
      <span class="meta">{t.articles_count(latest.length, sorted.length)}</span>
    </div>

    {latest.length === 0 ? (
      <div class="empty">
        <p>{t.no_news}</p>
      </div>
    ) : (
      <div class="news-grid">
        {latest.map((entry) => (
          <NewsCard
            locale={locale}
            slug={stripLocaleFromId(entry.id)}
            title={entry.data.title}
            summary={entry.data.summary}
            date={entry.data.date}
            source_name={entry.data.source_name}
            tags={entry.data.tags}
          />
        ))}
      </div>
    )}

    <FeaturedToken locale={locale} />
  </div>
</Layout>
