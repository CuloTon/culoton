---
import Layout from '../layouts/Layout.astro';
import LaunchContent from '../components/LaunchContent.astro';
import { LAUNCH_I18N } from '../data/launchI18n';

const locale = 'en' as const;
const t = LAUNCH_I18N[locale];
---

<Layout
  locale={locale}
  pathWithoutLocale="/launch"
  title={t.meta_title}
  description={t.meta_description}
>
  <LaunchContent locale={locale} />
</Layout>
