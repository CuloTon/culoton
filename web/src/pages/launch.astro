---
import Layout from '../layouts/Layout.astro';

const locale = 'en' as const;

const STONKS_PUMP = 'https://stonks.pump';
const TON_FOUNDATION_JETTON = 'https://docs.ton.org/develop/dapps/asset-processing/jettons';
const TONKEEPER = 'https://tonkeeper.com';
const TONHUB = 'https://tonhub.com';
const MYTONWALLET = 'https://mytonwallet.io';

const meta_title = 'Launch a TON jetton — BRAINROT';
const meta_description = 'Deploy your own TIP-3 jetton on TON via an audited launchpad. Connect a wallet, fill the form, optionally renounce admin. We charge nothing. Gas + launchpad fee are transparent.';
---

<Layout
  locale={locale}
  pathWithoutLocale="/launch"
  title={meta_title}
  description={meta_description}
>
  <article class="launch-page">
    <header class="launch-hero">
      <span class="kicker">Launch · TIP-3 Jetton on TON <span class="net-badge">TESTNET</span></span>
      <h1>Deploy your own TON jetton — right here.</h1>
      <p class="lede">
        Fill the form, connect your wallet, sign once. We build the deploy
        transaction in your browser using the <strong>audited TEP-74 reference
        Jetton Master</strong> — the same contract USDT-TON and Notcoin run on.
        We never touch your keys or your funds.
      </p>
      <p class="lede small">
        Currently live on <strong>TON testnet</strong> so you can try it with
        free coins before we open mainnet. We charge nothing — you only pay
        network gas (~0.2 TON, unused amount refunded to you).
      </p>
      <div class="hero-cta">
        <a class="cta-btn cta-primary cta-big" href="#deployer">Deploy below ↓</a>
        <span class="hero-cta-blurb">Need testnet TON? Grab free coins from @testgiver_ton_bot in Telegram.</span>
      </div>
    </header>

    <section class="block deployer" id="deployer">
      <div class="audit-header">
        <h2>Deploy a jetton</h2>
        <span class="net-badge">TESTNET</span>
      </div>
      <p class="block-lede">
        Metadata is written fully on-chain (TEP-64) — no IPFS, no server,
        nothing to rot. The logo is referenced by URL. 100% of supply mints
        to your wallet; you become admin and can renounce afterwards.
      </p>

      <button type="button" id="jl-connect" class="cta-btn cta-primary cta-big jl-connect">Connect TON wallet (testnet)</button>

      <form id="jl-form" class="jl-form" novalidate>
        <div class="jl-grid">
          <label class="jl-field">
            <span>Token name</span>
            <input id="jl-name" type="text" placeholder="e.g. BRAINROT Forever" maxlength="60" required />
          </label>
          <label class="jl-field">
            <span>Symbol</span>
            <input id="jl-symbol" type="text" placeholder="e.g. BRT" maxlength="12" required />
          </label>
          <label class="jl-field">
            <span>Decimals</span>
            <input id="jl-decimals" type="number" value="9" min="0" max="30" />
          </label>
          <label class="jl-field">
            <span>Total supply (whole tokens)</span>
            <input id="jl-supply" type="text" inputmode="numeric" placeholder="e.g. 1000000000" required />
          </label>
          <label class="jl-field jl-span">
            <span>Logo URL (optional)</span>
            <input id="jl-image" type="url" placeholder="https://… or ipfs://…" />
          </label>
          <label class="jl-field jl-span">
            <span>Description (optional)</span>
            <textarea id="jl-desc" rows="2" maxlength="500" placeholder="A short pitch — shown in wallets and explorers."></textarea>
          </label>
        </div>
        <button type="submit" id="jl-deploy" class="cta-btn cta-primary cta-big jl-deploy" disabled>Deploy jetton</button>
        <p id="jl-status" class="jl-status" role="status" aria-live="polite"></p>
      </form>

      <div id="jl-result" class="jl-result" hidden>
        <h3>Jetton deployed 🎉</h3>
        <p class="jl-result-row"><span>Address</span> <code id="jl-address"></code></p>
        <p class="jl-result-row">
          <a id="jl-explorer" href="#" target="_blank" rel="noopener noreferrer" class="jl-explorer-link">View on testnet explorer →</a>
        </p>
        <div class="jl-renounce-box">
          <p>Optional: renounce admin so nobody — including you — can ever mint more, edit metadata, or change admin. <strong>Irreversible.</strong></p>
          <button type="button" id="jl-renounce" class="cta-btn jl-renounce">Renounce admin</button>
        </div>
      </div>
    </section>

    <section class="block audit-block">
      <div class="audit-header">
        <h2>The contract you deploy</h2>
        <span class="audit-pill">Audited</span>
      </div>
      <p class="audit-lede">
        We don't ship our own smart contract. The deploy uses the official
        <strong>TEP-74 reference Jetton Master</strong> maintained by the TON
        Foundation — the exact contract behind USDT-TON, Notcoin and most major
        TON tokens. We wrap it, we don't modify a byte.
      </p>
      <ul class="audit-list">
        <li>
          <strong>Audited &amp; battle-tested</strong>
          <p>The reference jetton master in ton-blockchain/token-contract was audited before mainnet and has settled billions in volume on USDT and NOT with zero contract-level incidents.</p>
        </li>
        <li>
          <strong>Standard TEP-74 / TEP-89</strong>
          <p>Your token is a vanilla TON jetton. Tonkeeper, tonviewer, STON.fi and DeDust recognise it with no custom integration.</p>
        </li>
        <li>
          <strong>We wrap, we don't modify</strong>
          <p>The launcher only assembles the StateInit + mint message and hands it to your wallet. Your wallet, your signature, official bytecode. No hidden message in the deploy.</p>
        </li>
        <li>
          <strong>Renounce when ready</strong>
          <p>One transaction sets admin to the null address. After it, nobody — not us, not you — can mint more, edit metadata, or change admin.</p>
        </li>
      </ul>
      <p class="audit-foot">
        The exact code cells we deploy are lifted verbatim from @ton-community/assets-sdk and embedded in our open-source frontend. Caveat: an audit is not a guarantee — verify before you trust real value to any token.
      </p>
    </section>

    <section class="block">
      <h2>Three steps</h2>
      <p class="block-lede">
        End-to-end, this takes about five minutes once your wallet is funded.
      </p>
      <ol class="flow-steps">
        <li>
          <div class="flow-n">1</div>
          <div class="flow-body">
            <h3>Get a TON wallet with funds</h3>
            <p>
              Install
              <a href={TONKEEPER} target="_blank" rel="noopener noreferrer">Tonkeeper</a>,
              <a href={TONHUB} target="_blank" rel="noopener noreferrer">Tonhub</a>, or
              <a href={MYTONWALLET} target="_blank" rel="noopener noreferrer">MyTonWallet</a>.
              Top it up with around 5 TON to cover gas plus the launchpad fee with a margin.
            </p>
          </div>
        </li>
        <li>
          <div class="flow-n">2</div>
          <div class="flow-body">
            <h3>Fill the form and connect</h3>
            <p>
              In the deployer above enter <em>name, symbol, decimals (use 9),
              total supply</em> and optionally a description and logo URL. Hit
              <em>Connect TON wallet</em> — TON Connect pairs with any of the
              wallets above. Your seed phrase never touches this page.
            </p>
          </div>
        </li>
        <li>
          <div class="flow-n">3</div>
          <div class="flow-body">
            <h3>Sign once, then optionally renounce</h3>
            <p>
              Your wallet shows one transaction (~0.2 TON, excess refunded). Sign
              it. Within ~10 seconds your jetton is on-chain with 100% of supply
              in your wallet. A renounce button then lets you lock admin forever
              in one more transaction.
            </p>
          </div>
        </li>
      </ol>
    </section>

    <section class="block">
      <h2>What it costs</h2>
      <table class="pricing-table">
        <tbody>
          <tr>
            <td class="p-label">BRAINROT platform fee</td>
            <td class="p-value">0 TON</td>
            <td class="p-note">We add nothing to the transaction. No cut of supply.</td>
          </tr>
          <tr>
            <td class="p-label">Deploy + mint transaction</td>
            <td class="p-value">~0.2 TON</td>
            <td class="p-note">Attached value; unused amount is refunded to you. Goes to validators.</td>
          </tr>
          <tr>
            <td class="p-label">On-chain metadata (TEP-64)</td>
            <td class="p-value">included</td>
            <td class="p-note">No IPFS, no pinning fee. Stored in the contract itself.</td>
          </tr>
          <tr>
            <td class="p-label">Optional: renounce admin tx</td>
            <td class="p-value">~0.05 TON</td>
            <td class="p-note">One more gas-only transaction.</td>
          </tr>
          <tr>
            <td class="p-label">Testnet TON</td>
            <td class="p-value">free</td>
            <td class="p-note">From @testgiver_ton_bot. Mainnet uses real TON.</td>
          </tr>
        </tbody>
      </table>
      <p class="pricing-disclaimer">
        Numbers are network gas, not our fee — your wallet shows the exact amount before you sign, and any excess comes back to you. Right now everything runs on TON testnet, so the coins are free.
      </p>
    </section>

    <section class="block">
      <h2>What you should know</h2>
      <ul class="why-list">
        <li>
          <strong>Memecoins are gambling</strong>
          <p>Most jettons go to zero within days. Do not put in money you cannot lose. If you are deploying for fun, that is fine — say so.</p>
        </li>
        <li>
          <strong>Renounce vs. keep admin</strong>
          <p>Renouncing builds trust but removes recovery. Keeping admin means you can fix mistakes — and so can anyone who steals your wallet.</p>
        </li>
        <li>
          <strong>Image hosting</strong>
          <p>Your token image lives off-chain. stonks.pump uploads to IPFS by default. Don't use copyrighted art unless you own it.</p>
        </li>
        <li>
          <strong>Regulatory exposure</strong>
          <p>You are the issuer. EU and US rules around marketing a token to retail are non-trivial. Talk to a lawyer before you do paid promotion.</p>
        </li>
      </ul>
    </section>

    <section class="block">
      <h2>Alternatives</h2>
      <p class="block-lede">
        Prefer to do it another way? Deploy a standard jetton yourself with the official TON Foundation contracts, or use a managed launchpad with built-in LP and trading tooling.
      </p>
      <ul class="wallets-list">
        <li><a href={STONKS_PUMP} target="_blank" rel="noopener noreferrer">stonks.pump launchpad</a></li>
        <li><a href={TON_FOUNDATION_JETTON} target="_blank" rel="noopener noreferrer">TON jetton dev guide</a></li>
        <li><a href="https://github.com/ton-blockchain/token-contract" target="_blank" rel="noopener noreferrer">Reference Jetton contract</a></li>
        <li><a href="https://github.com/ton-org/blueprint" target="_blank" rel="noopener noreferrer">TON Blueprint (CLI)</a></li>
      </ul>
    </section>

    <section class="block cta-final">
      <h2>Ready?</h2>
      <p>Connect a testnet wallet and try it now. A couple of minutes, ~0.2 TON of free testnet gas, and your jetton is live on-chain.</p>
      <a class="cta-btn cta-primary cta-big" href="#deployer">Go to the deployer ↑</a>
    </section>

    <p class="legal">
      Disclaimer: BRAINROT (the editorial portal at brainrot-ton.fun) does not custody funds, hold your keys, sign transactions on your behalf, or take a cut of supply. The launcher assembles a deploy transaction in your browser from the audited TEP-74 reference contract; everything is signed in your own wallet under your control. The deployer currently targets TON <strong>testnet</strong>. Cryptocurrency carries financial and regulatory risk; this page is not financial advice.
    </p>
  </article>
</Layout>

<script>
  import '../scripts/launcher.ts';
</script>

<style>
  .launch-page {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 24px;
  }

  /* === Testnet badge === */
  .net-badge {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #6dd4a8;
    border: 1px solid rgba(109, 212, 168, 0.5);
    border-radius: 4px;
    padding: 3px 8px;
    vertical-align: middle;
    margin-left: 8px;
  }

  /* === Deployer === */
  .deployer { scroll-margin-top: 90px; }
  .jl-connect { margin: 8px 0 24px; }
  .jl-connect[data-connected="true"] {
    background: var(--bg-section);
    color: var(--text-dim);
    border-color: var(--rule-soft);
  }
  .jl-form { margin-top: 8px; }
  .jl-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px 20px;
  }
  .jl-field { display: flex; flex-direction: column; gap: 6px; }
  .jl-field.jl-span { grid-column: 1 / -1; }
  .jl-field > span {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--accent-text);
    font-weight: 700;
  }
  .jl-field input,
  .jl-field textarea {
    font-family: var(--font-sans);
    font-size: 16px;
    color: var(--text);
    background: var(--bg-section);
    border: 1px solid var(--rule);
    border-radius: 0;
    padding: 12px 14px;
    width: 100%;
    resize: vertical;
  }
  .jl-field input:focus,
  .jl-field textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 2px var(--accent-soft, rgba(244,197,66,0.25));
  }
  .jl-deploy { margin-top: 22px; }
  .jl-status {
    margin: 16px 0 0;
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.5;
    min-height: 18px;
  }
  .jl-status[data-kind="error"] { color: var(--danger); }
  .jl-status[data-kind="ok"] { color: #2e9c6b; }
  .jl-status[data-kind="info"] { color: var(--text-mute); }
  .jl-result {
    margin-top: 28px;
    padding: 24px;
    background: var(--bg-section);
    border: 1px solid #6dd4a8;
    border-left-width: 3px;
  }
  .jl-result h3 {
    margin: 0 0 14px;
    font-family: var(--font-display);
    font-size: 22px;
    color: var(--text);
  }
  .jl-result-row {
    margin: 8px 0;
    font-family: var(--font-serif);
    font-size: 16px;
    color: var(--text-dim);
    word-break: break-all;
  }
  .jl-result-row code {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--accent-text);
  }
  .jl-explorer-link { color: var(--accent-text); }
  .jl-renounce-box {
    margin-top: 18px;
    padding-top: 16px;
    border-top: 1px solid var(--rule-soft);
  }
  .jl-renounce-box p {
    margin: 0 0 12px;
    font-family: var(--font-serif);
    font-size: 15px;
    color: var(--text-mute);
    line-height: 1.6;
  }
  .jl-renounce {
    background: transparent;
    color: var(--danger);
    border: 1px solid var(--danger);
    padding: 12px 22px;
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .jl-renounce:hover { background: rgba(179, 23, 61, 0.08); }
  @media (max-width: 600px) {
    .jl-grid { grid-template-columns: 1fr; }
  }

  .launch-hero {
    margin: 32px 0 48px;
    padding-bottom: 36px;
    border-bottom: 1px solid var(--rule);
  }
  .kicker {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent-text);
    margin-bottom: 24px;
  }
  .launch-hero h1 {
    margin: 0 0 24px;
    font-family: var(--font-display);
    font-size: clamp(40px, 6vw, 64px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: #ffffff;
    font-weight: 800;
  }
  .launch-hero .lede {
    font-family: var(--font-serif);
    font-size: 22px;
    line-height: 1.55;
    color: var(--text-dim);
    margin: 0 0 16px;
    max-width: 640px;
  }
  .launch-hero .lede.small {
    font-size: 17px;
    color: var(--text-mute);
  }
  .launch-hero .lede strong {
    color: var(--accent-text);
    font-weight: 600;
  }

  .hero-cta {
    display: flex;
    align-items: center;
    gap: 18px;
    flex-wrap: wrap;
    margin-top: 28px;
  }
  .hero-cta-blurb {
    color: var(--text-mute);
    font-size: 14px;
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
  }

  .cta-btn {
    display: inline-block;
    text-decoration: none !important;
    border-bottom: none !important;
    transition: background 0.15s, color 0.15s;
  }
  .cta-primary {
    background: transparent;
    color: var(--accent-text);
    border: 1px solid var(--accent);
    padding: 14px 26px;
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }
  .cta-primary:hover {
    background: var(--accent-soft);
    color: var(--accent);
  }
  .cta-big {
    padding: 16px 30px;
    font-size: 14px;
  }

  .block { margin: 0 0 64px; }
  .block h2 {
    margin: 0 0 16px;
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 32px);
    color: #ffffff;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--rule);
    font-weight: 700;
  }
  .block-lede {
    font-family: var(--font-serif);
    color: var(--text-dim);
    font-size: 18px;
    line-height: 1.6;
    margin: 0 0 24px;
    max-width: 600px;
  }

  /* Why list (cards) */
  .why-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 16px;
  }
  .why-list li {
    background: var(--bg-section);
    border-left: 2px solid var(--accent);
    padding: 18px 22px;
  }
  .why-list strong {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent-text);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    margin-bottom: 10px;
    font-weight: 700;
  }
  .why-list p {
    margin: 0;
    font-family: var(--font-serif);
    color: var(--text-dim);
    font-size: 17px;
    line-height: 1.6;
  }

  /* Audit block */
  .audit-block {
    background: transparent;
    border-left: 2px solid #6dd4a8;
    padding: 0 0 0 24px;
  }
  .audit-header {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 14px;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--rule);
  }
  .audit-header h2 {
    margin: 0;
    border: none;
    padding: 0;
  }
  .audit-pill {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #6dd4a8;
    border: 1px solid rgba(109, 212, 168, 0.45);
    padding: 4px 10px;
  }
  .audit-lede {
    font-family: var(--font-serif);
    color: var(--text-dim);
    font-size: 18px;
    line-height: 1.6;
    margin: 0 0 22px;
    max-width: 600px;
  }
  .audit-list {
    list-style: none;
    padding: 0;
    margin: 0 0 22px;
    display: grid;
    gap: 14px;
  }
  .audit-list li {
    padding: 16px 20px;
    background: var(--bg-section);
    border-left: 2px solid #6dd4a8;
  }
  .audit-list strong {
    display: block;
    color: #6dd4a8;
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    margin-bottom: 8px;
    font-weight: 700;
  }
  .audit-list p {
    margin: 0;
    font-family: var(--font-serif);
    color: var(--text-dim);
    font-size: 16px;
    line-height: 1.6;
  }
  .audit-foot {
    margin: 18px 0 0;
    padding: 14px 18px;
    background: rgba(109, 212, 168, 0.06);
    border: 1px solid rgba(109, 212, 168, 0.2);
    color: var(--text-dim);
    font-style: italic;
    font-family: var(--font-serif);
    font-size: 15px;
    line-height: 1.6;
  }

  /* Flow steps */
  .flow-steps {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .flow-steps li {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: 20px;
    align-items: flex-start;
    padding: 22px 0;
    border-bottom: 1px solid var(--rule-soft);
  }
  .flow-steps li:last-child { border-bottom: none; }
  .flow-n {
    font-family: var(--font-display);
    font-size: 44px;
    font-weight: 800;
    color: var(--accent);
    line-height: 1;
    letter-spacing: -0.04em;
  }
  .flow-body h3 {
    margin: 0 0 8px;
    font-family: var(--font-display);
    font-size: 22px;
    color: #ffffff;
    font-weight: 700;
  }
  .flow-body p {
    margin: 0;
    font-family: var(--font-serif);
    color: var(--text-dim);
    font-size: 17px;
    line-height: 1.65;
  }
  .flow-body a {
    color: var(--accent-text);
  }
  .flow-body em {
    font-style: italic;
    color: var(--text);
  }

  /* Pricing table */
  .pricing-table {
    width: 100%;
    border-collapse: collapse;
    border-top: 1px solid var(--rule);
    margin-top: 8px;
  }
  .pricing-table td {
    padding: 16px 12px;
    border-bottom: 1px solid var(--rule-soft);
    vertical-align: top;
    font-family: var(--font-serif);
    font-size: 16px;
  }
  .p-label {
    color: var(--text);
    width: 42%;
  }
  .p-value {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--accent-text);
    white-space: nowrap;
    letter-spacing: 0.04em;
  }
  .p-note {
    color: var(--text-mute);
    font-size: 14px;
    font-style: italic;
  }
  .pricing-disclaimer {
    margin: 22px 0 0;
    font-family: var(--font-serif);
    color: var(--text-mute);
    font-size: 15px;
    line-height: 1.6;
    font-style: italic;
  }

