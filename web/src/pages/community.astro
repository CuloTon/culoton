---
import Layout from '../layouts/Layout.astro';
import BlogApp from '../components/BlogApp.astro';

const locale = 'en' as const;
---

<Layout
  locale={locale}
  pathWithoutLocale="/community"
  title="Blog — write, get upvoted, earn BRTP"
  description="The BRAINROT community blog: write in your language, get upvoted by others and earn BRTP points paid out to your TON address."
>
  <BlogApp />
</Layout>
