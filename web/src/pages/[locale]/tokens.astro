---
import Layout from '../../layouts/Layout.astro';
import TokenGallery from '../../components/TokenGallery.astro';
import type { Locale } from '../../i18n/strings';

export function getStaticPaths() {
  return [
    { params: { locale: 'ru' } },
    { params: { locale: 'pl' } },
    { params: { locale: 'de' } },
    { params: { locale: 'es' } },
    { params: { locale: 'uk' } },
  ];
}

const { locale } = Astro.params as { locale: Locale };

const META: Record<string, { title: string; description: string }> = {
  ru: { title: 'Лента токенов — джеттоны на BRAINROT', description: 'Каждый джеттон GRAM, развёрнутый через лаунчер BRAINROT, прямо из тестнета. Non-custodial, проверенный код TEP-74.' },
  pl: { title: 'Feed tokenów — jettony z launchera BRAINROT', description: 'Każdy jetton GRAM wdrożony przez launcher BRAINROT, prosto z testnetu. Non-custodial, zaudytowany kod TEP-74.' },
  de: { title: 'Token-Feed — Jettons von BRAINROT', description: 'Jeder GRAM-Jetton, der über den BRAINROT-Launcher deployt wurde, direkt aus dem Testnet. Non-custodial, geprüfter TEP-74-Code.' },
  es: { title: 'Feed de tokens — jettons de BRAINROT', description: 'Cada jetton de GRAM desplegado con el launcher de BRAINROT, directo desde la testnet. Non-custodial, código TEP-74 auditado.' },
  uk: { title: 'Стрічка токенів — джетони BRAINROT', description: 'Кожен джетон GRAM, розгорнутий через лаунчер BRAINROT, прямо з тестнету. Non-custodial, перевірений код TEP-74.' },
};
const m = META[locale] ?? META.pl;
---

<Layout
  locale={locale}
  pathWithoutLocale="/tokens"
  title={m.title}
  description={m.description}
>
  <TokenGallery locale={locale} />
</Layout>
