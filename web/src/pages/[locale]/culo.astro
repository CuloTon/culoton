---
import Layout from '../../layouts/Layout.astro';
import { UI, type Locale } from '../../i18n/strings';

export async function getStaticPaths() {
  return [
    { params: { locale: 'ru' } },
    { params: { locale: 'pl' } },
    { params: { locale: 'de' } },
  ];
}

const { locale } = Astro.params as { locale: Locale };
const t = UI[locale];
const TELEGRAM = 'https://t.me/culoton';
const CONTRACT = 'EQD5dCm196cT60OTcCz_MI_f_QtpZYGU5mazX-4rjAOHiKrJ';
---

<Layout
  locale={locale}
  pathWithoutLocale="/culo"
  title={t.culo_title}
  description={t.culo_meta_description}
>
  <article class="news-article">
    <div style="text-align: center; margin-bottom: 28px;">
      <img src="/culo.png" alt="$CULO token" style="width: 140px; height: 140px; border-radius: 50%; border: 3px solid var(--accent); margin: 0 auto;" />
    </div>

    <h1 style="text-align: center;"><span style="color: var(--accent); font-family: var(--font-mono);">$CULO</span></h1>

    <p class="article-summary" style="text-align: center; border-left: none; padding-left: 0;">
      {t.culo_summary}
    </p>

    <div class="ton-cta-row">
      <a class="cta-btn cta-primary" href={TELEGRAM} target="_blank" rel="noopener noreferrer">
        {t.culo_cta_join}
      </a>
      <a class="cta-btn cta-secondary" href={`https://tonviewer.com/${CONTRACT}`} target="_blank" rel="noopener noreferrer">
        {t.culo_cta_view}
      </a>
    </div>

    <div class="contract-box">
      <span class="contract-label">{t.culo_contract_label}</span>
      <code class="contract-value" id="contract-value">{CONTRACT}</code>
      <button class="copy-btn" type="button" id="copy-btn" data-value={CONTRACT} data-label-copy={t.culo_copy} data-label-copied={t.culo_copied} data-label-failed={t.culo_copy_failed}>{t.culo_copy}</button>
    </div>

    <div class="body">
      <h2 style="font-size: 22px; margin-top: 36px; color: var(--accent);">{t.culo_understanding_h}</h2>

      <p set:html={t.culo_understanding_p1_html} />
      <p set:html={t.culo_understanding_p2_html} />

      <h2 style="font-size: 22px; margin-top: 36px; color: var(--accent);">{t.culo_track_h}</h2>
      <ul class="track-record">
        <li set:html={t.culo_track_li1_html} />
        <li set:html={t.culo_track_li2_html} />
        <li set:html={t.culo_track_li3_html} />
      </ul>

      <h2 style="font-size: 22px; margin-top: 36px; color: var(--accent);">{t.culo_why_h}</h2>
      <p>{t.culo_why_p}</p>

      <h2 style="font-size: 22px; margin-top: 36px; color: var(--accent);">{t.culo_community_h}</h2>
      <p set:html={t.culo_community_p_html} />

      <h2 style="font-size: 22px; margin-top: 36px; color: var(--accent);">{t.culo_disclaimer_h}</h2>
      <p style="font-size: 14px; color: var(--text-mute);">
        {t.culo_disclaimer_p}
      </p>
    </div>
  </article>
</Layout>

<style>
  .ton-cta-row {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin: 24px 0 12px;
  }
  .cta-btn {
    display: inline-block;
    padding: 12px 22px;
    border-radius: 8px;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.02em;
    transition: transform 0.12s, opacity 0.12s;
  }
  .cta-btn:hover { transform: translateY(-1px); opacity: 0.92; }
  .cta-primary { background: var(--accent); color: #1a1408 !important; }
  .cta-secondary {
    background: transparent;
    border: 1px solid var(--ton);
    color: var(--ton) !important;
  }

  .contract-box {
    margin: 18px auto 0;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 16px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    max-width: 760px;
  }
  .contract-label {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-mute);
    flex-shrink: 0;
  }
  .contract-value {
    flex: 1;
    min-width: 200px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text);
    word-break: break-all;
    background: transparent;
    padding: 0;
  }
  .copy-btn {
    background: var(--accent);
    color: #1a1408;
    border: none;
    padding: 6px 14px;
    border-radius: 5px;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .copy-btn:hover { opacity: 0.9; }
  .copy-btn.copied { background: #4ade80; }

  .track-record {
    padding-left: 20px;
    margin: 16px 0;
  }
  .track-record li {
    margin-bottom: 8px;
    color: var(--text-dim);
  }
  .track-record strong {
    color: var(--text);
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('copy-btn');
    if (!btn) return;
    btn.addEventListener('click', async () => {
      const value = btn.getAttribute('data-value') || '';
      const labelCopied = btn.getAttribute('data-label-copied') || 'Copied!';
      const labelCopy = btn.getAttribute('data-label-copy') || 'Copy';
      const labelFailed = btn.getAttribute('data-label-failed') || 'Copy failed';
      try {
        await navigator.clipboard.writeText(value);
        btn.textContent = labelCopied;
        btn.classList.add('copied');
        setTimeout(() => {
          btn.textContent = labelCopy;
          btn.classList.remove('copied');
        }, 1500);
      } catch (e) {
        btn.textContent = labelFailed;
      }
    });
  });
</script>
