---
import Layout from '../../layouts/Layout.astro';
import { UI, type Locale } from '../../i18n/strings';

export async function getStaticPaths() {
  return [
    { params: { locale: 'ru' } },
    { params: { locale: 'pl' } },
    { params: { locale: 'de' } },
    { params: { locale: 'es' } },
    { params: { locale: 'uk' } },
  ];
}

const { locale } = Astro.params as { locale: Locale };
const t = UI[locale];
const TELEGRAM = 'https://t.me/culoton';
const CONTRACT = 'EQAYaqIikryTucQEz3IGRC62M7Eo4rzvduFAV5iWZ1b0A2Uc';

const HOW = {
  pl: {
    h: 'Jak działa system CULO TON',
    intro: 'CULO TON to dwie rzeczy ściśle ze sobą sprzężone: redakcja newsowa o ekosystemie TON oraz token bez TAX siedzący w jej środku. Po redakcję ludzie przychodzą; token finansuje redakcję i nagradza społeczność budowaną wokół niej.',
    pillars: [
      ['📰 Redakcja newsowa', 'CuloScribe, nasz redaktor AI, pobiera RSS-y z głównych publikacji o ekosystemie TON, odsiewa to co już opisaliśmy, i opowiada każdą historię własnymi słowami w czterech językach (EN/RU/PL/DE). Około 24 newsy dziennie plus trzy redakcyjne podsumowania (rano, południe, wieczór), które syntetyzują dany odcinek w jednym tekście.'],
      ['🤖 Bot Telegramowy', '@cscriber_bot żyje na naszym czacie t.me/culoton. /news daje ostatnie 6h newsów. /price culoton pobiera dane rynkowe z GeckoTerminal na żywo. /ask odpowiada przez Claude Haiku z ostatnimi 50 newsami EN jako kontekstem. /points i /leaderboard śledzą aktywność, a dzienny /quiz spada o 17:00 czasu polskiego.'],
      ['🏆 Tygodniowa pula nagród', 'Najaktywniejszy członek tygodnia dostaje 5 TON, wypłacane w każdą niedzielę o 20:00 UTC. Aktywność = posty, wygrane quizy, użycie /ask, ranking. Bez farmienia — limit 20 punktów na osobę dziennie.'],
      ['📡 Publikacja wielokanałowa', 'Każda historia leci automatycznie na Telegram (@culoton) i X (@culoton_). Market pulse dla $CULOTON wychodzi 4× dziennie na obu kanałach, dane z GeckoTerminal. Trzy podsumowania dziennie lądują na blogu culoton.fun/blog.'],
      ['💎 Token $CULOTON', 'Jetton na TON bez TAX, kontrakt EQAYaqIikry…b0A2Uc. Token jest brandowym ramieniem platformy — nie jest papierem wartościowym ani produktem yieldowym. Holderzy dostają tę samą treść co wszyscy, a projekt finansuje rozwój z aktywności po stronie tokenu.'],
    ],
    closer: 'Wszystko wychodzi z jednego repo GitHub, na cronie. Astro statyczne, Python ingest, Claude Haiku rewrites, GitHub Actions schedule, deploy FTP. Żadnych modów, żadnych shillerów, żadnych obietnic poza łańcuchem — kod otwarty na github.com/CuloTon.',
  },
  ru: {
    h: 'Как работает система CULO TON',
    intro: 'CULO TON — это две вещи в одной связке: редакция новостей об экосистеме TON и tax-free мем-коин в её центре. Ради редакции люди приходят; токен её финансирует и вознаграждает сообщество, которое строится вокруг.',
    pillars: [
      ['📰 Редакция', 'CuloScribe, наш AI-редактор, забирает RSS из основных публикаций об экосистеме TON, отсеивает уже освещённое и пересказывает каждую историю своим голосом на четырёх языках (EN/RU/PL/DE). Около 24 новостей в день плюс три редакционных дайджеста (утро, полдень, вечер), синтезирующих период в один материал.'],
      ['🤖 Telegram-бот', '@cscriber_bot живёт в чате t.me/culoton. /news — последние 6ч новостей. /price culoton — рыночные данные с GeckoTerminal в реальном времени. /ask отвечает через Claude Haiku с последними 50 EN-новостями как контекстом. /points и /leaderboard отслеживают активность, ежедневный /quiz выпадает в 17:00 по польскому времени.'],
      ['🏆 Еженедельный призовой фонд', 'Самый активный участник недели получает 5 TON, выплата каждое воскресенье в 20:00 UTC. Активность = посты, победы в квизах, использование /ask, подъём в рейтинге. Без фарма — лимит 20 очков на человека в день.'],
      ['📡 Публикация по каналам', 'Каждая история автоматически уходит в Telegram (@culoton) и X (@culoton_). Market pulse $CULOTON выходит 4 раза в день на обоих каналах, данные с GeckoTerminal. Три дайджеста в день оседают в блоге culoton.fun/blog.'],
      ['💎 Токен $CULOTON', 'Jetton на TON без TAX, контракт EQAYaqIikry…b0A2Uc. Токен — это бренд-нога платформы, не ценная бумага и не yield-продукт. Холдеры получают тот же контент, что и все, а проект финансирует разработку через активность вокруг токена.'],
    ],
    closer: 'Всё выходит из одного GitHub-репозитория, по cron. Astro static, Python ingest, Claude Haiku rewrites, GitHub Actions schedule, FTP deploy. Без модов, без шиллеров, без обещаний вне цепочки — код открыт на github.com/CuloTon.',
  },
  de: {
    h: 'Wie das CULO TON System funktioniert',
    intro: 'CULO TON ist zweierlei, eng gekoppelt: eine Nachrichtenredaktion für das TON-Ökosystem und ein steuerfreier Memecoin in ihrer Mitte. Wegen der Redaktion kommen die Leute; der Token finanziert die Redaktion und belohnt die Community, die sich darum bildet.',
    pillars: [
      ['📰 Die Redaktion', 'CuloScribe, unser KI-Redakteur, liest RSS-Feeds der wichtigsten TON-Publikationen, dedupliziert bereits Behandeltes und erzählt jede Story in eigener Stimme über vier Sprachen (EN/RU/PL/DE). Etwa 24 News am Tag plus drei redaktionelle Roundups (Morgen, Mittag, Abend), die den Zeitraum in einen Text bündeln.'],
      ['🤖 Der Telegram-Bot', '@cscriber_bot lebt im Chat t.me/culoton. /news liefert die News der letzten 6h. /price culoton zieht live Marktdaten von GeckoTerminal. /ask antwortet via Claude Haiku mit den letzten 50 EN-News als Kontext. /points und /leaderboard tracken Aktivität, das tägliche /quiz fällt um 17:00 PL.'],
      ['🏆 Wöchentlicher Preispool', 'Das aktivste Mitglied jede Woche erhält 5 TON, ausgezahlt jeden Sonntag um 20:00 UTC. Aktivität = Posts, Quiz-Siege, /ask-Nutzung, Leaderboard-Aufstieg. Kein Farming — Cap bei 20 Punkten pro Person und Tag.'],
      ['📡 Cross-Channel-Publishing', 'Jede Story geht automatisch an Telegram (@culoton) und X (@culoton_). $CULOTON-Marktimpulse 4× täglich auf beiden Kanälen, Daten live von GeckoTerminal. Drei Roundups pro Tag landen im Blog auf culoton.fun/blog.'],
      ['💎 Der $CULOTON-Token', 'Steuerfreies TON-Jetton, Vertrag EQAYaqIikry…b0A2Uc. Der Token ist das Brand-Bein der Plattform — kein Wertpapier und kein Yield-Produkt. Halter bekommen denselben Content wie alle, und das Projekt finanziert die Entwicklung über Token-seitige Aktivität.'],
    ],
    closer: 'Alles läuft aus einem GitHub-Repo per Cron. Astro Static Site, Python-Ingest, Claude Haiku Rewrites, GitHub Actions Schedule, FTP-Deploy. Keine Mods, keine Shiller, keine Off-Chain-Versprechen — Code offen auf github.com/CuloTon.',
  },
} as const;
const how = HOW[(locale as 'pl' | 'ru' | 'de')] ?? HOW.ru;  // es/uk fall back to ru
---

<Layout
  locale={locale}
  pathWithoutLocale="/culo"
  title={t.culo_title}
  description={t.culo_meta_description}
>
  <article class="news-article">
    <div style="text-align: center; margin-bottom: 28px;">
      <img src="/culo.png" alt="$CULOTON token" style="width: 140px; height: 140px; border-radius: 50%; border: 3px solid var(--accent); margin: 0 auto;" />
    </div>

    <h1 style="text-align: center;"><span style="color: var(--accent); font-family: var(--font-mono);">$CULOTON</span></h1>

    <p class="article-summary" style="text-align: center; border-left: none; padding-left: 0;">
      {t.culo_summary}
    </p>

    <div class="ton-cta-row">
      <a class="cta-btn cta-primary" href={TELEGRAM} target="_blank" rel="noopener noreferrer">
        {t.culo_cta_join}
      </a>
      <a class="cta-btn cta-secondary" href={`https://tonviewer.com/${CONTRACT}`} target="_blank" rel="noopener noreferrer">
        {t.culo_cta_view}
      </a>
    </div>

    <div class="contract-box">
      <span class="contract-label">{t.culo_contract_label}</span>
      <code class="contract-value" id="contract-value">{CONTRACT}</code>
      <button class="copy-btn" type="button" id="copy-btn" data-value={CONTRACT} data-label-copy={t.culo_copy} data-label-copied={t.culo_copied} data-label-failed={t.culo_copy_failed}>{t.culo_copy}</button>
    </div>

    <div class="body">
      <h2 style="font-size: 22px; margin-top: 36px; color: var(--accent);">{t.culo_understanding_h}</h2>

      <p set:html={t.culo_understanding_p1_html} />
      <p set:html={t.culo_understanding_p2_html} />

      <h2 style="font-size: 22px; margin-top: 36px; color: var(--accent);">{how.h}</h2>
      <p>{how.intro}</p>
      <ul class="how-pillars">
        {how.pillars.map(([title, body]) => (
          <li>
            <strong>{title}</strong>
            <p>{body}</p>
          </li>
        ))}
      </ul>
      <p style="font-size: 14px; color: var(--text-mute); margin-top: 12px;">{how.closer}</p>

      <h2 style="font-size: 22px; margin-top: 36px; color: var(--accent);">{t.culo_track_h}</h2>
      <ul class="track-record">
        <li set:html={t.culo_track_li1_html} />
        <li set:html={t.culo_track_li2_html} />
        <li set:html={t.culo_track_li3_html} />
      </ul>

      <h2 style="font-size: 22px; margin-top: 36px; color: var(--accent);">{t.culo_why_h}</h2>
      <p>{t.culo_why_p}</p>

      <h2 style="font-size: 22px; margin-top: 36px; color: var(--accent);">{t.culo_community_h}</h2>
      <p set:html={t.culo_community_p_html} />

      <h2 style="font-size: 22px; margin-top: 36px; color: var(--accent);">{t.culo_disclaimer_h}</h2>
      <p style="font-size: 14px; color: var(--text-mute);">
        {t.culo_disclaimer_p}
      </p>
    </div>
  </article>
</Layout>

<style>
  .ton-cta-row {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin: 24px 0 12px;
  }
  .cta-btn {
    display: inline-block;
    padding: 12px 22px;
    border-radius: 8px;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.02em;
    transition: transform 0.12s, opacity 0.12s;
  }
  .cta-btn:hover { transform: translateY(-1px); opacity: 0.92; }
  .cta-primary { background: var(--accent); color: #1a1408 !important; }
  .cta-secondary {
    background: transparent;
    border: 1px solid var(--ton);
    color: var(--ton) !important;
  }

  .contract-box {
    margin: 18px auto 0;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 16px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    max-width: 760px;
  }
  .contract-label {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-mute);
    flex-shrink: 0;
  }
  .contract-value {
    flex: 1;
    min-width: 200px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text);
    word-break: break-all;
    background: transparent;
    padding: 0;
  }
  .copy-btn {
    background: var(--accent);
    color: #1a1408;
    border: none;
    padding: 6px 14px;
    border-radius: 5px;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .copy-btn:hover { opacity: 0.9; }
  .copy-btn.copied { background: #4ade80; }

  .track-record {
    padding-left: 20px;
    margin: 16px 0;
  }
  .track-record li {
    margin-bottom: 8px;
    color: var(--text-dim);
  }
  .track-record strong {
    color: var(--text);
  }

  .how-pillars {
    list-style: none;
    padding: 0;
    margin: 16px 0;
  }
  .how-pillars > li {
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 18px;
    margin-bottom: 10px;
  }
  .how-pillars strong {
    display: block;
    color: var(--accent);
    font-size: 14px;
    letter-spacing: 0.02em;
    margin-bottom: 4px;
  }
  .how-pillars p {
    margin: 0;
    font-size: 14px;
    line-height: 1.55;
    color: var(--text-dim);
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const btn = document.getElementById('copy-btn');
    if (!btn) return;
    btn.addEventListener('click', async () => {
      const value = btn.getAttribute('data-value') || '';
      const labelCopied = btn.getAttribute('data-label-copied') || 'Copied!';
      const labelCopy = btn.getAttribute('data-label-copy') || 'Copy';
      const labelFailed = btn.getAttribute('data-label-failed') || 'Copy failed';
      try {
        await navigator.clipboard.writeText(value);
        btn.textContent = labelCopied;
        btn.classList.add('copied');
        setTimeout(() => {
          btn.textContent = labelCopy;
          btn.classList.remove('copied');
        }, 1500);
      } catch (e) {
        btn.textContent = labelFailed;
      }
    });
  });
</script>
