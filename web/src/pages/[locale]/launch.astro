---
import Layout from '../../layouts/Layout.astro';
import LaunchContent from '../../components/LaunchContent.astro';
import { LAUNCH_I18N } from '../../data/launchI18n';
import type { Locale } from '../../i18n/strings';

export function getStaticPaths() {
  return [
    { params: { locale: 'ru' } },
    { params: { locale: 'pl' } },
    { params: { locale: 'de' } },
    { params: { locale: 'es' } },
    { params: { locale: 'uk' } },
  ];
}

const { locale } = Astro.params as { locale: Locale };
const t = LAUNCH_I18N[locale];
---

<Layout
  locale={locale}
  pathWithoutLocale="/launch"
  title={t.meta_title}
  description={t.meta_description}
>
  <LaunchContent locale={locale} />
</Layout>
