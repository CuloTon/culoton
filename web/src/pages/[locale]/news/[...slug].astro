---
import { getCollection, render } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import { UI, DATE_LOCALE, localizedPath, LOCALES, LOCALE_FULL, type Locale } from '../../../i18n/strings';

export async function getStaticPaths() {
  const out: any[] = [];

  for (const loc of ['ru', 'pl', 'de', 'es', 'uk'] as Locale[]) {
    let entries;
    if (loc === 'ru') entries = await getCollection('news_ru');
    else if (loc === 'pl') entries = await getCollection('news_pl');
    else if (loc === 'es') entries = await getCollection('news_es');
    else if (loc === 'uk') entries = await getCollection('news_uk');
    else entries = await getCollection('news_de');

    for (const entry of entries) {
      out.push({
        params: {
          locale: loc,
          slug: entry.id.replace(/^[a-z]{2}\//, '').replace(/\.md$/, ''),
        },
        props: { entry, locale: loc },
      });
    }
  }
  return out;
}

const { entry, locale } = Astro.props as { entry: any; locale: Locale };
const t = UI[locale];
const { Content } = await render(entry);

const slug = entry.id.replace(/^[a-z]{2}\//, '').replace(/\.md$/, '');

const formattedDate = entry.data.date.toLocaleDateString(DATE_LOCALE[locale], {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Discover sibling locales for "Also in:"
const otherLocales: Locale[] = [];
for (const loc of LOCALES) {
  if (loc === locale) continue;
  let coll;
  if (loc === 'en') coll = await getCollection('news_en');
  else if (loc === 'ru') coll = await getCollection('news_ru');
  else if (loc === 'pl') coll = await getCollection('news_pl');
  else if (loc === 'es') coll = await getCollection('news_es');
  else if (loc === 'uk') coll = await getCollection('news_uk');
  else coll = await getCollection('news_de');
  if (coll.some((e: any) => e.id === `${loc}/${slug}.md`)) {
    otherLocales.push(loc);
  }
}
---

<Layout
  locale={locale}
  pathWithoutLocale={`/news/${slug}`}
  title={`${entry.data.title} — CuloTon`}
  description={entry.data.summary}
>
  <article class="news-article">
    <div class="breadcrumb">
      <a href={localizedPath(locale, '/')}>{t.nav_news}</a> &nbsp;/&nbsp; <span>{entry.data.source_name}</span>
    </div>

    <h1>{entry.data.title}</h1>

    <div class="article-meta">
      <span class="meta-date">{t.date_label} {formattedDate}</span>
      <span class="meta-source">{t.source_label} {entry.data.source_name}</span>
      {entry.data.tags.length > 0 && (
        <span class="meta-tags">
          {entry.data.tags.map((tag: string) => <span class="tag">{tag}</span>)}
        </span>
      )}
    </div>

    <p class="article-summary">{entry.data.summary}</p>

    <div class="body">
      <Content />
    </div>

    <div class="source-attribution">
      <strong>Source:</strong> {t.source_attribution_lead}{' '}
      <a href={entry.data.source_url} target="_blank" rel="noopener noreferrer">
        {entry.data.source_name}
      </a>
      .{' '}
      <a href={entry.data.original_url} target="_blank" rel="noopener noreferrer">
        {t.read_original}
      </a>
    </div>

    <div class="culoscribe-byline">
      <img src="/culoscribe.png" alt="CuloScribe AI" />
      <div>
        <strong>CuloScribe AI</strong>
        <span>{t.footer_edited_by}</span>
      </div>
    </div>

    {otherLocales.length > 0 && (
      <div class="other-langs">
        <span class="other-langs-label">Also in:</span>
        {otherLocales.map((loc) => (
          <a href={localizedPath(loc, `/news/${slug}`)}>{LOCALE_FULL[loc]}</a>
        ))}
      </div>
    )}
  </article>
</Layout>

<style>
  .meta-date, .meta-source { flex-shrink: 0; }
  .meta-tags {
    display: inline-flex;
    flex-wrap: wrap;
    gap: 4px;
    min-width: 0;
    max-width: 100%;
  }
  .culoscribe-byline {
    display: flex;
    align-items: center;
    gap: 14px;
    margin: 36px 0 22px;
    padding: 18px 20px;
    background: var(--bg-section);
    border-left: 4px solid var(--accent);
    border-radius: 0;
  }
  .culoscribe-byline img {
    width: 48px; height: 48px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--text);
  }
  .culoscribe-byline strong {
    display: block;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .culoscribe-byline span {
    font-size: 14px;
    color: var(--text-dim);
    font-family: var(--font-display);
    font-style: italic;
  }
  .other-langs {
    margin-top: 22px;
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-mute);
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .other-langs-label { font-weight: 700; color: var(--text); }
  .other-langs a {
    color: var(--text);
    border-bottom: 1px solid var(--rule-soft);
  }
  .other-langs a:hover { color: var(--accent-hot); border-bottom-color: var(--accent); }
</style>
