---
import Layout from '../../layouts/Layout.astro';
import PollResults from '../../components/PollResults.astro';

export async function getStaticPaths() {
  return [
    { params: { locale: 'pl' } },
    { params: { locale: 'de' } },
    { params: { locale: 'ru' } },
    { params: { locale: 'es' } },
    { params: { locale: 'uk' } },
  ];
}

type PollLocale = 'pl' | 'de' | 'ru' | 'es' | 'uk';
const { locale } = Astro.params as { locale: PollLocale };

const HEADINGS = {
  pl: { kicker: 'Zamknięte · Decyzja społeczności', h1: 'Tokenomika $BRT — Twoja decyzja', intro: 'Społeczność miała głos w sprawie tego, jak ma działać nowy kontrakt $BRT. Zapytaliśmy, zagłosowaliście, oto wynik.' },
  de: { kicker: 'Geschlossen · Community-Entscheidung', h1: '$BRT-Tokenomics — eure Stimme', intro: 'Die Community hatte das Wort, wie der neue $BRT-Vertrag funktionieren soll. Wir fragten, ihr stimmtet ab — hier das Ergebnis.' },
  ru: { kicker: 'Закрыто · Решение сообщества', h1: 'Токеномика $BRT — ваш выбор', intro: 'Сообщество высказалось о том, как должен работать новый контракт $BRT. Мы спросили, вы проголосовали, вот итог.' },
  es: { kicker: 'Cerrado · Decisión de la comunidad', h1: 'Tokenomics de $BRT — tu voto', intro: 'La comunidad tuvo la palabra sobre cómo debe comportarse el nuevo contrato $BRT. Preguntamos, votasteis, aquí el resultado.' },
  uk: { kicker: 'Закрите · Рішення спільноти', h1: 'Токеноміка $BRT — ваш вибір', intro: 'Спільнота мала право голосу щодо того, як має працювати новий контракт $BRT. Ми запитали, ви проголосували, ось результат.' },
};
const h = HEADINGS[locale];
---

<Layout
  locale={locale}
  pathWithoutLocale="/poll"
  title={h.h1 + ' — BRAINROT'}
  description={h.intro}
>
  <article class="poll-page">
    <header class="poll-hero">
      <span class="kicker">{h.kicker}</span>
      <h1>{h.h1}</h1>
      <p class="poll-intro">{h.intro}</p>
    </header>

    <PollResults locale={locale} />
  </article>
</Layout>

<style>
  .poll-page {
    max-width: 820px;
    margin: 2.5rem auto;
    padding: 0 1rem;
  }
  .poll-hero {
    margin-bottom: 1rem;
  }
  .poll-hero .kicker {
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.7;
  }
  .poll-hero h1 {
    font-size: clamp(1.7rem, 4vw, 2.4rem);
    margin: 0.4rem 0 1rem;
    line-height: 1.18;
  }
  .poll-intro {
    margin: 0 0 0.85rem;
    line-height: 1.6;
    opacity: 0.9;
  }
</style>
