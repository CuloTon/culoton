---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import { DATE_LOCALE, localizedPath, LOCALES, LOCALE_FULL, type Locale } from '../../../i18n/strings';

export async function getStaticPaths() {
  const out: any[] = [];
  for (const loc of ['ru', 'pl', 'de'] as const) {
    const coll =
      loc === 'ru' ? await getCollection('pulse_ru') :
      loc === 'pl' ? await getCollection('pulse_pl') :
                     await getCollection('pulse_de');
    for (const entry of coll) {
      const slug = entry.id.replace(/^[a-z]{2}\//, '').replace(/\.md$/, '');
      out.push({ params: { locale: loc, slug }, props: { entry } });
    }
  }
  return out;
}

interface Props {
  entry: CollectionEntry<'pulse_ru' | 'pulse_pl' | 'pulse_de'>;
}

const { entry } = Astro.props as Props;
const { locale } = Astro.params as { locale: Locale; slug: string };
const { Content } = await render(entry as any);
const slug = entry.id.replace(/^[a-z]{2}\//, '').replace(/\.md$/, '');

const formattedDate = entry.data.date.toLocaleDateString(DATE_LOCALE[locale], {
  year: 'numeric', month: 'long', day: 'numeric',
  hour: '2-digit', minute: '2-digit',
});

const SLOT_LABEL: Record<Locale, Record<string, string>> = {
  en: { morning: 'Morning Pulse', afternoon: 'Afternoon Pulse', overnight: 'Overnight Pulse' } as any,
  ru: { morning: 'Утренний пульс', afternoon: 'Дневной пульс', overnight: 'Ночной пульс' },
  pl: { morning: 'Poranny puls', afternoon: 'Popołudniowy puls', overnight: 'Nocny puls' },
  de: { morning: 'Morgenpuls', afternoon: 'Nachmittagspuls', overnight: 'Nachtpuls' },
};

const COPY: Record<Locale, { messages: string; voices: string; back: string; byline: string; }> = {
  en: {} as any,
  ru: {
    messages: 'сообщений',
    voices: 'Голоса в этом слоте',
    back: '← Назад в sTONks Pulse',
    byline: 'Из живого чата sTONks. Цитаты дословные. Редакционная подача — не инвестиционный совет.',
  },
  pl: {
    messages: 'wiadomości',
    voices: 'Głosy w tym slocie',
    back: '← Wróć do sTONks Pulse',
    byline: 'Z żywego czatu sTONks. Cytaty dosłowne. Ujęcie redakcyjne — nie porada inwestycyjna.',
  },
  de: {
    messages: 'Nachrichten',
    voices: 'Stimmen in diesem Slot',
    back: '← Zurück zu sTONks Pulse',
    byline: 'Aus dem Live-sTONks-Chat. Zitate wortgetreu. Redaktionelle Einordnung — keine Anlageberatung.',
  },
};

const otherLocales: Locale[] = [];
for (const loc of LOCALES) {
  if (loc === locale) continue;
  const coll =
    loc === 'ru' ? await getCollection('pulse_ru') :
    loc === 'pl' ? await getCollection('pulse_pl') :
    loc === 'de' ? await getCollection('pulse_de') :
                   await getCollection('pulse_en');
  if (coll.some((e: any) => e.id === `${loc}/${slug}.md`)) {
    otherLocales.push(loc);
  }
}

const c = COPY[locale];
const labels = SLOT_LABEL[locale];
---

<Layout
  locale={locale}
  pathWithoutLocale={`/pulse/${slug}`}
  title={`${entry.data.title} — sTONks Pulse`}
  description={entry.data.summary}
>
  <article class="news-article">
    <div class="breadcrumb">
      <a href={localizedPath(locale, '/pulse')}>sTONks Pulse</a> &nbsp;/&nbsp; <span>{labels[entry.data.slot]}</span>
    </div>

    <div class="pulse-hero-card">
      <span class={`slot-pill slot-${entry.data.slot}`}>{labels[entry.data.slot]}</span>
      <h1>{entry.data.title}</h1>
      <div class="article-meta">
        <span class="meta-date">{formattedDate} UTC</span>
        <span class="meta-count">{entry.data.message_count} {c.messages}</span>
        <span class="meta-source">via <a href={`https://${entry.data.source_chat}`} target="_blank" rel="noopener noreferrer">{entry.data.source_chat}</a></span>
      </div>
      <p class="article-summary">{entry.data.summary}</p>
    </div>

    <div class="body">
      <Content />
    </div>

    <div class="culoscribe-byline">
      <img src="/culoscribe.png" alt="CuloScribe AI" />
      <div>
        <strong>CuloScribe AI</strong>
        <span>{c.byline}</span>
      </div>
    </div>

    {entry.data.participants.length > 0 && (
      <div class="participants">
        <h3>{c.voices}</h3>
        <div class="participant-tags">
          {entry.data.participants.map((p: string) => (
            <span class="participant">{p}</span>
          ))}
        </div>
      </div>
    )}

    <div class="back-row">
      <a href={localizedPath(locale, '/pulse')}>{c.back}</a>
    </div>

    {otherLocales.length > 0 && (
      <div class="other-langs">
        <span class="other-langs-label">Also in:</span>
        {otherLocales.map((loc) => (
          <a href={localizedPath(loc, `/pulse/${slug}`)}>{LOCALE_FULL[loc]}</a>
        ))}
      </div>
    )}
  </article>
</Layout>

<style>
  .pulse-hero-card {
    margin: 0 0 28px;
    padding: 0 0 26px;
    background: transparent;
    border: none;
    border-bottom: 2px solid var(--rule);
    border-radius: 0;
  }
  .pulse-hero-card h1 {
    margin: 14px 0 16px;
    line-height: 1.05;
    font-size: 52px;
    letter-spacing: -0.025em;
  }
  .pulse-hero-card .article-summary {
    border-left: 4px solid var(--accent);
    padding: 8px 0 8px 22px;
    margin-top: 18px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 22px;
    line-height: 1.4;
    color: var(--text);
  }
  @media (max-width: 720px) {
    .pulse-hero-card h1 { font-size: 32px; }
    .pulse-hero-card .article-summary { font-size: 18px; padding-left: 16px; }
  }
  .meta-date, .meta-count, .meta-source { flex-shrink: 0; }
  .slot-pill {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    padding: 4px 10px;
    border-radius: 0;
    text-transform: uppercase;
  }
  .slot-morning { background: #fef3c7; color: #92400e; border: 1px solid #f59e0b; }
  .slot-afternoon { background: #dbeafe; color: #075985; border: 1px solid #0ea5e9; }
  .slot-overnight { background: #ede9fe; color: #5b21b6; border: 1px solid #8b5cf6; }
  .culoscribe-byline {
    display: flex;
    align-items: center;
    gap: 14px;
    margin: 36px 0 22px;
    padding: 18px 20px;
    background: var(--bg-section);
    border-left: 4px solid var(--accent);
    border-radius: 0;
  }
  .culoscribe-byline img {
    width: 48px; height: 48px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid var(--text);
  }
  .culoscribe-byline strong {
    display: block;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .culoscribe-byline span {
    font-size: 14px;
    color: var(--text-dim);
    font-family: var(--font-display);
    font-style: italic;
  }
  .participants {
    margin-top: 28px;
    padding: 20px 22px;
    background: var(--bg-section);
    border-top: 2px solid var(--rule);
  }
  .participants h3 {
    margin: 0 0 12px;
    font-size: 12px;
    color: var(--text);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .participant-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .participant {
    font-family: var(--font-mono);
    font-size: 13px;
    background: var(--bg);
    border: 1px solid var(--rule-soft);
    padding: 4px 10px;
    color: var(--text-dim);
  }
  .back-row {
    margin: 30px 0 10px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .back-row a {
    color: var(--text);
    border-bottom: 1px solid var(--rule);
  }
  .other-langs {
    margin-top: 18px;
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-mute);
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .other-langs-label { font-weight: 700; color: var(--text); }
  .other-langs a {
    color: var(--text);
    border-bottom: 1px solid var(--rule-soft);
  }
</style>
