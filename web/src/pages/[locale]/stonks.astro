    trade_h: 'Die Trading-Seite',
    trade_lead: 'Über die Build-Pipeline hinaus liefert sTONks einen vollständigen Trading-Stack:',
    trade_li_html: [
      '<strong>Trading Terminal</strong> — Multi-Wallet, Sniper-Bot, TradingView-Charts, Limit Orders, On-Chain Fills, Sub-100ms-Execution.',
