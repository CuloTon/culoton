    next_trader: 'das Trading-Terminal im Telegram-DM',
    next_chat: 'Community-Chat, in dem Launches in Echtzeit diskutiert werden',
    next_culo: 'Verfolge $CULO live',
    next_news: 'Aktuelle TON-Nachrichten',
