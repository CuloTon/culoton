---
import Layout from '../../layouts/Layout.astro';
import type { Locale } from '../../i18n/strings';

export async function getStaticPaths() {
  return [
    { params: { locale: 'ru' } },
    { params: { locale: 'pl' } },
    { params: { locale: 'de' } },
  ];
}

const { locale } = Astro.params as { locale: Locale };
const STONKS_SITE = 'https://stonksbots.com/';
const STONKS_TRADER = 'https://t.me/stonks_sniper_bot';
const TG_STONKSONTON = 'https://t.me/stonksonton';

type Copy = {
  title: string;
  meta: string;
  h1: string;
  summary_html: string;
  what_h: string;
  what_p1: string;
  pipeline_li: string[];
  what_numbers_html: string;
  trade_h: string;
  trade_lead: string;
  trade_li_html: string[];
  rwa_h: string;
  rwa_p1: string;
  rwa_p2: string;
  origin_h: string;
  origin_p1_html: string;
  origin_p2: string;
  why_h: string;
  why_p1: string;
  why_p2: string;
  next_h: string;
  next_site: string;
  next_trader: string;
  next_chat: string;
  next_culo: string;
  next_news: string;
  living_html: string;
  breadcrumb_news: string;
};

const COPY: Record<Locale, Copy> = {
  en: {} as Copy, // not used; primary EN page lives at /stonks
  ru: {
    title: 'sTONks — on-chain экосистема, на которой запустили $CULO',
    meta: 'Что такое sTONks, как работает пайплайн build-to-trade и как на нём запустили $CULO.',
    h1: 'sTONks — on-chain экосистема, на которой запустили $CULO',
    summary_html: '$CULO появился не на пустом месте. Он был запущен на <strong><a href="' + STONKS_SITE + '" target="_blank" rel="noopener noreferrer">sTONks</a></strong> — end-to-end on-chain платформе, которая позволяет билдить, деплоить, токенизировать и торговать в одном месте, всё на TON. Разбираем что это значит.',
    what_h: 'Что такое sTONks на самом деле',
    what_p1: 'sTONks — это не просто лаунчпад. Это четырёхступенчатый on-chain пайплайн, замыкающий цикл от написания кода до торговли результатом:',
