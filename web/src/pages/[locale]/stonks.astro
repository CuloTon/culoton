const c = COPY[locale];
---

<Layout
  locale={locale}
  pathWithoutLocale="/stonks"
  title={c.title}
  description={c.meta}
>
  <article class="news-article">
    <div class="breadcrumb">
      <a href={`/${locale}/`}>{c.breadcrumb_news}</a> &nbsp;/&nbsp; <span>sTONks</span>
    </div>

    <h1>{c.h1}</h1>

    <p class="article-summary" set:html={c.summary_html} />

    <div class="body">
      <h2>{c.what_h}</h2>
      <p>{c.what_p1}</p>
      <ol>
        {c.pipeline_li.map((item) => (<li set:html={item} />))}
      </ol>
      <p set:html={c.what_numbers_html} />

      <h2>{c.trade_h}</h2>
      <p>{c.trade_lead}</p>
      <ul>
        {c.trade_li_html.map((item) => (<li set:html={item} />))}
      </ul>

      <h2>{c.rwa_h}</h2>
      <p>{c.rwa_p1}</p>
      <p>{c.rwa_p2}</p>

      <h2>{c.origin_h}</h2>
      <p set:html={c.origin_p1_html} />
      <p>{c.origin_p2}</p>

      <h2>{c.why_h}</h2>
      <p>{c.why_p1}</p>
      <p>{c.why_p2}</p>

      <h2>{c.next_h}</h2>
      <ul>
        <li>🌐 <a href={STONKS_SITE} target="_blank" rel="noopener noreferrer">stonksbots.com</a> — {c.next_site}.</li>
        <li>🤖 <a href={STONKS_TRADER} target="_blank" rel="noopener noreferrer">@stonks_sniper_bot</a> — {c.next_trader}.</li>
        <li>💬 <a href={TG_STONKSONTON} target="_blank" rel="noopener noreferrer">t.me/stonksonton</a> — {c.next_chat}.</li>
        <li>🟡 <a href={`/${locale}/culo`}>{c.next_culo}</a></li>
        <li>📰 <a href={`/${locale}/`}>{c.next_news}</a></li>
      </ul>

      <p set:html={c.living_html} />
    </div>
  </article>
</Layout>
