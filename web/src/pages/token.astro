---
import Layout from '../layouts/Layout.astro';
import TokenListings from '../components/TokenListings.astro';

const locale = 'en' as const;
---

<Layout
  locale={locale}
  pathWithoutLocale="/token"
  title="Token board — curated GRAM jettons with live charts"
  description="Hand-picked GRAM jettons with a live token/USD chart, market cap and 24h volume. Data live from GeckoTerminal with a DexScreener fallback."
>
  <TokenListings locale={locale} />
</Layout>
