---
import Layout from '../layouts/Layout.astro';
import PollResults from '../components/PollResults.astro';
---

<Layout
  locale="en"
  pathWithoutLocale="/poll"
  title="Tokenomics vote — BRAINROT"
  description="Community vote on $BRT tokenomics. Closed with 38 votes — final result: 25% buy tax, 25% sell tax, 50% of revenue distributed to holders."
>
  <article class="poll-page">
    <header class="poll-hero">
      <span class="kicker">Closed · Community decision</span>
      <h1>$BRT tokenomics — your call</h1>
      <p class="poll-intro">The community had the floor on how the new $BRT contract should behave. We asked, you voted, the dust has settled.</p>
    </header>

    <PollResults locale="en" />
  </article>
</Layout>

<style>
  .poll-page {
    max-width: 820px;
    margin: 2.5rem auto;
    padding: 0 1rem;
  }
  .poll-hero {
    margin-bottom: 1rem;
  }
  .poll-hero .kicker {
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.7;
  }
  .poll-hero h1 {
    font-size: clamp(1.7rem, 4vw, 2.4rem);
    margin: 0.4rem 0 1rem;
    line-height: 1.18;
  }
  .poll-intro {
    margin: 0 0 0.85rem;
    line-height: 1.6;
    opacity: 0.9;
  }
</style>
