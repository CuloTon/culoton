---
import Layout from '../layouts/Layout.astro';
import PollWidget from '../components/PollWidget.astro';
import { POLL_STRINGS } from '../data/pollStrings';

const locale = 'en' as const;
const s = POLL_STRINGS[locale];
---

<Layout
  locale="en"
  pathWithoutLocale="/poll"
  title={s.pageTitle}
  description={s.metaDescription}
>
  <article class="poll-page">
    <header class="poll-hero">
      <span class="kicker">{s.kicker}</span>
      <h1>{s.h1}</h1>
      {s.intro.map((p) => <p class="poll-intro">{p}</p>)}
    </header>

    <PollWidget locale="en" />
  </article>
</Layout>

<style>
  .poll-page {
    max-width: 820px;
    margin: 2.5rem auto;
    padding: 0 1rem;
  }
  .poll-hero {
    margin-bottom: 1rem;
  }
  .poll-hero .kicker {
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    opacity: 0.7;
  }
  .poll-hero h1 {
    font-size: clamp(1.7rem, 4vw, 2.4rem);
    margin: 0.4rem 0 1rem;
    line-height: 1.18;
  }
  .poll-intro {
    margin: 0 0 0.85rem;
    line-height: 1.6;
    opacity: 0.9;
  }
</style>
