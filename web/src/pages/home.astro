---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import NewsCard from '../components/NewsCard.astro';
import FeaturedToken from '../components/FeaturedToken.astro';
import StatsBadge from '../components/StatsBadge.astro';
import { UI, DATE_LOCALE, localizedPath } from '../i18n/strings';
import { dedupeByTitle } from '../lib/dedupeNews';

const locale = 'en' as const;
const t = UI[locale];

const allNews = await getCollection('news_en');
const sorted = allNews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const deduped = dedupeByTitle(sorted);
const latest = deduped.slice(0, 24);

const allBlog = await getCollection('blog_en');
const sortedBlog = allBlog.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latestBlog = sortedBlog.slice(0, 3);

function stripLocaleFromId(id: string): string {
  return id.replace(/^en\//, '').replace(/\.md$/, '');
}

const lead = latest[0];
const secondary = latest.slice(1, 3);
const rest = latest.slice(3);

function fmt(d: Date) {
  return d.toLocaleDateString(DATE_LOCALE[locale], {
    year: 'numeric', month: 'short', day: 'numeric',
  });
}
---

<Layout
  locale={locale}
  pathWithoutLocale="/"
  title={t.site_title}
  description={t.site_description}
>
  <div class="container">
    {lead ? (
      <section class="feature-hero">
        <div class="lead">
          <span class="kicker">{t.hero_badge}</span>
          <h1><a href={localizedPath(locale, `/news/${stripLocaleFromId(lead.id)}`)}>{lead.data.title}</a></h1>
          <p>{lead.data.summary}</p>
          <div class="lead-meta">
            <span>{lead.data.source_name}</span>
            <span> · </span>
            <span>{fmt(lead.data.date)}</span>
          </div>
        </div>
        <div class="secondary">
          {secondary.map((entry) => (
            <div class="sec-card">
              <div class="source">{entry.data.source_name}</div>
              <h3><a href={localizedPath(locale, `/news/${stripLocaleFromId(entry.id)}`)}>{entry.data.title}</a></h3>
              <p>{entry.data.summary}</p>
            </div>
          ))}
        </div>
      </section>
    ) : (
      <section class="hero-banner">
        <div>
          <span class="badge">{t.hero_badge}</span>
          <h1 set:html={t.hero_headline_html} />
          <p>{t.hero_blurb}</p>
        </div>
      </section>
    )}

    {latestBlog.length > 0 && (
      <section class="blog-section">
        <div class="section-title">
          <h2>{t.blog_section_h}</h2>
          <a class="meta-link" href={localizedPath(locale, '/blog')}>{t.blog_section_view_all} →</a>
        </div>
        <p class="blog-section-blurb">{t.blog_section_blurb}</p>
        <div class="blog-cards">
          {latestBlog.map((entry) => {
            const bSlug = stripLocaleFromId(entry.id);
            const bDate = entry.data.date.toLocaleDateString(DATE_LOCALE[locale], {
              year: 'numeric', month: 'short', day: 'numeric',
            });
            return (
              <a class={`blog-card kind-${entry.data.kind}`} href={localizedPath(locale, `/blog/${bSlug}`)}>
                <span class="kind-pill">{t.blog_kind_label(entry.data.kind)}</span>
                <h3>{entry.data.title}</h3>
                <p>{entry.data.summary}</p>
                <span class="blog-card-date">{bDate}</span>
              </a>
            );
          })}
        </div>
      </section>
    )}

    {rest.length > 0 && (
      <>
        <div class="section-title">
          <h2>{t.latest_news}</h2>
          <span class="meta">{t.articles_count(latest.length, sorted.length)}</span>
        </div>
        <div class="news-grid">
          {rest.map((entry) => (
            <NewsCard
              locale={locale}
              slug={stripLocaleFromId(entry.id)}
              title={entry.data.title}
              summary={entry.data.summary}
              date={entry.data.date}
              source_name={entry.data.source_name}
              tags={entry.data.tags}
            />
          ))}
        </div>
        <p class="archive-link-row">
          <a href={localizedPath(locale, '/archive')}>{t.archive_view_all}</a>
        </p>
      </>
    )}

    {latest.length === 0 && (
      <div class="empty">
        <p>{t.no_news}</p>
      </div>
    )}

    <StatsBadge locale={locale} />

    <FeaturedToken locale={locale} />
  </div>
</Layout>

<style>
  .archive-link-row {
    margin: 28px 0 8px;
    text-align: right;
  }
  .archive-link-row a {
    font-family: var(--font-mono);
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text);
    border-bottom: 1px solid var(--rule);
    padding-bottom: 2px;
    text-decoration: none;
  }
  .archive-link-row a:hover {
    color: var(--accent-hot, var(--accent));
    border-bottom-color: var(--accent);
  }
  .blog-section {
    margin: 44px 0;
    padding: 28px 0 32px;
    background: transparent;
    border: none;
    border-top: 2px solid var(--rule);
    border-bottom: 2px solid var(--rule);
    border-radius: 0;
  }
  .blog-section .section-title {
    border-bottom: none;
    margin: 0 0 6px;
    padding-bottom: 0;
  }
  .blog-section h2 { margin: 0; }
  .blog-section .meta-link {
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-bottom: 1px solid var(--rule);
  }
  .blog-section .meta-link:hover {
    color: var(--accent-hot);
    border-bottom-color: var(--accent);
  }
  .blog-section-blurb {
    color: var(--text-mute);
    font-family: var(--font-display);
    font-style: italic;
    font-size: 16px;
    line-height: 1.55;
    margin: 6px 0 22px;
    max-width: 720px;
  }
  .blog-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 0;
    border-top: 1px solid var(--rule-soft);
  }
  .blog-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 22px 22px 22px 0;
    background: transparent;
    border: none;
    border-right: 1px solid var(--rule-soft);
    border-radius: 0;
    text-decoration: none;
    color: inherit;
    transition: background 0.12s;
    position: relative;
  }
  .blog-card:last-child { border-right: none; }
  .blog-card:first-child { padding-left: 0; }
  .blog-card:not(:first-child) { padding-left: 22px; }
  .blog-card:hover { background: var(--bg-section); }
  .blog-card .kind-pill {
    display: inline-block;
    align-self: flex-start;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    padding: 3px 9px;
    border-radius: 0;
    text-transform: uppercase;
  }
  .blog-card.kind-morning .kind-pill { background: #fef3c7; color: #92400e; border: 1px solid #f59e0b; }
  .blog-card.kind-noon .kind-pill { background: #dbeafe; color: #075985; border: 1px solid #0ea5e9; }
  .blog-card.kind-evening .kind-pill { background: #ede9fe; color: #5b21b6; border: 1px solid #8b5cf6; }
  .blog-card h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: 20px;
    line-height: 1.2;
    color: var(--text);
    letter-spacing: -0.01em;
  }
  .blog-card p {
    margin: 0;
    color: var(--text-dim);
    font-size: 14px;
    line-height: 1.5;
    flex: 1;
  }
  .blog-card-date {
    font-size: 11px;
    color: var(--text-mute);
    font-family: var(--font-mono);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  @media (max-width: 920px) {
    .blog-cards { grid-template-columns: 1fr; }
    .blog-card { border-right: none; border-bottom: 1px solid var(--rule-soft); padding: 18px 0; }
    .blog-card:not(:first-child) { padding-left: 0; }
    .blog-card:last-child { border-bottom: none; }
  }
</style>
