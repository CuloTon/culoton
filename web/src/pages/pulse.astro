---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { DATE_LOCALE, localizedPath } from '../i18n/strings';

const locale = 'en' as const;

const all = await getCollection('pulse_en');
const sorted = all.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

function stripLocaleFromId(id: string): string {
  return id.replace(/^en\//, '').replace(/\.md$/, '');
}

const SLOT_LABEL = {
  morning: 'Morning Pulse',
  afternoon: 'Afternoon Pulse',
  overnight: 'Overnight Pulse',
};
---

<Layout
  locale={locale}
  pathWithoutLocale="/pulse"
  title="sTONks Pulse — community chat summary"
  description="Three times a day, CuloScribe reads the public sTONks Telegram chat and summarises what was discussed."
>
  <div class="container">
    <section class="hero-banner">
      <div>
        <span class="badge">Community pulse</span>
        <h1>sTONks Pulse</h1>
        <p>
          Three times a day CuloScribe reads the public
          <a href="https://t.me/stonksonton" target="_blank" rel="noopener noreferrer">sTONks chat</a>
          and writes a summary — what was discussed, who said what, where there was a debate.
          Source-attributed, dryly editorial, no hype.
        </p>
      </div>
    </section>

    {sorted.length === 0 ? (
      <div class="empty"><p>No pulse summaries yet — first one drops with the next slot.</p></div>
    ) : (
      <div class="pulse-list">
        {sorted.map((entry) => {
          const slug = stripLocaleFromId(entry.id);
          const formatted = entry.data.date.toLocaleDateString(DATE_LOCALE[locale], {
            year: 'numeric', month: 'long', day: 'numeric',
            hour: '2-digit', minute: '2-digit',
          });
          return (
            <a class="pulse-list-card" href={localizedPath(locale, `/pulse/${slug}`)}>
              <div class="pulse-list-meta">
                <span class={`slot-pill slot-${entry.data.slot}`}>{SLOT_LABEL[entry.data.slot]}</span>
                <span class="pulse-list-date">{formatted} UTC</span>
                <span class="pulse-list-count">{entry.data.message_count} messages</span>
              </div>
              <h2>{entry.data.title}</h2>
              <p>{entry.data.summary}</p>
            </a>
          );
        })}
      </div>
    )}
  </div>
</Layout>

<style>
  .pulse-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-top: 2px solid var(--rule);
  }
  .pulse-list-card {
    display: block;
    padding: 28px 0;
    background: transparent;
    border: none;
    border-bottom: 1px solid var(--rule-soft);
    border-radius: 0;
    text-decoration: none;
    color: inherit;
    transition: background 0.12s, padding-left 0.12s;
    position: relative;
  }
  .pulse-list-card:hover {
    background: var(--bg-section);
    padding-left: 18px;
  }
  .pulse-list-card::after {
    content: "→";
    position: absolute;
    right: 8px;
    top: 28px;
    font-family: var(--font-mono);
    font-size: 22px;
    color: var(--accent-hot);
    opacity: 0;
    transform: translateX(-6px);
    transition: opacity 0.15s, transform 0.15s;
  }
  .pulse-list-card:hover::after { opacity: 1; transform: translateX(0); }
  .pulse-list-meta {
    display: flex;
    gap: 14px;
    align-items: center;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }
  .slot-pill {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    padding: 4px 10px;
    border-radius: 0;
    text-transform: uppercase;
  }
  .slot-morning { background: #fef3c7; color: #92400e; border: 1px solid #f59e0b; }
  .slot-afternoon { background: #dbeafe; color: #075985; border: 1px solid #0ea5e9; }
  .slot-overnight { background: #ede9fe; color: #5b21b6; border: 1px solid #8b5cf6; }
  .pulse-list-date,
  .pulse-list-count {
    font-size: 12px;
    color: var(--text-mute);
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .pulse-list-card h2 {
    font-family: var(--font-display);
    font-size: 28px;
    margin: 0 0 10px;
    line-height: 1.2;
    letter-spacing: -0.015em;
    color: var(--text);
    padding-right: 40px;
  }
  .pulse-list-card p {
    margin: 0;
    color: var(--text-dim);
    font-size: 17px;
    line-height: 1.5;
    max-width: 760px;
  }
  @media (max-width: 720px) {
    .pulse-list-card { padding: 22px 0; }
    .pulse-list-card:hover { padding-left: 12px; }
    .pulse-list-card h2 { font-size: 22px; }
    .pulse-list-card p { font-size: 15px; }
  }
</style>
