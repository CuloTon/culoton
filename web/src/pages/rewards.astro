---
import Layout from '../layouts/Layout.astro';
import RewardsContent from '../components/RewardsContent.astro';

const locale = 'en' as const;
---

<Layout
  locale={locale}
  pathWithoutLocale="/rewards"
  title="$BRT holder rewards — TON revenue share"
  description="BRAINROT shares TON revenue with $BRT holders: 50% of the project bank every round — 25% to all holders + 25% to the top 10 (paid from both pools), pro-rata. Formula, exclusions and the 0.05 TON rollover explained."
>
  <RewardsContent locale={locale} />
</Layout>
