---
import Layout from '../layouts/Layout.astro';
import RewardsContent from '../components/RewardsContent.astro';

const locale = 'en' as const;
---

<Layout
  locale={locale}
  pathWithoutLocale="/rewards"
  title="$BRT holder rewards — TON revenue share"
  description="BRAINROT shares TON revenue with $BRT holders: 25% of the project bank, paid pro-rata every week. Formula, exclusions and the 0.05 TON rollover explained."
>
  <RewardsContent locale={locale} />
</Layout>
