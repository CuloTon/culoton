---
import Layout from '../layouts/Layout.astro';
import { UI } from '../i18n/strings';

const locale = 'en' as const;
const t = UI[locale];
const TELEGRAM = 'https://t.me/culoton';
const CONTRACT = 'EQAYaqIikryTucQEz3IGRC62M7Eo4rzvduFAV5iWZ1b0A2Uc';
const CTAX_CONTRACT = 'EQC4fCG7nZQiLSSoy7LUXj4EZhB092PC-pj1Upx5CJQUopY9';
const CTAX_IMG = 'https://img.stonks.cash/3dd96acf-040d-459d-8fcc-04f09d51bb43.png';

const HOW = {
  en: {
    h: 'How the CULO TON system works',
    intro: 'CULO TON is two things, tightly coupled: an editorial news desk for the TON ecosystem, and a tax-free memecoin sitting at the centre of it. The desk is what people show up for; the token is what funds the desk and rewards the community building around it.',
    pillars: [
      ['📰 The news desk', 'CuloScribe, our AI editor, ingests RSS feeds from the major TON-ecosystem publications, deduplicates against what we already covered, and re-reports each story in its own voice across four languages (EN/RU/PL/DE). About 24 stories a day, plus three editorial roundups (morning, noon, evening) that synthesise the period into one read.'],
      ['🤖 The Telegram bot', '@cscriber_bot lives in our chat at t.me/culoton. /news pulls the last 6h of stories. /price culoton returns live market data from GeckoTerminal. /ask gives you a Haiku-grounded answer using the latest 50 EN stories as context. /points and /leaderboard track activity, and the daily /quiz drops at 17:00 PL.'],
      ['🏆 Weekly prize pool', 'The most active member each week earns 5 TON paid out every Sunday at 20:00 UTC. Activity = posts, quiz wins, /ask usage, leaderboard climb. No farming — there is a 20-points-per-day cap.'],
      ['📡 Cross-channel publishing', 'Each story is auto-pushed to Telegram (@culoton) and X (@culoton_). Market pulses for $CULOTON go out 4× a day on both channels, sourced live from GeckoTerminal. Three roundups a day land on the blog at culoton.fun/blog.'],
      ['💎 The $CULOTON token', 'Tax-free TON jetton, contract EQAYaqIikry…b0A2Uc. The token is the brand leg of the platform — it is not a security and not a yield product. Holders get the same content as everyone, and the project funds development with token-side activity.'],
    ],
    closer: 'Everything ships from one GitHub repo, on cron. Astro static site, Python ingest, Claude Haiku rewrites, GitHub Actions schedule, FTP deploy. No mods, no shillers, no off-chain promises — code is open at github.com/CuloTon.',
  },
  pl: {
    h: 'Jak działa system CULO TON',
    intro: 'CULO TON to dwie rzeczy ściśle ze sobą sprzężone: redakcja newsowa o ekosystemie TON oraz token bez TAX siedzący w jej środku. Po redakcję ludzie przychodzą; token finansuje redakcję i nagradza społeczność budowaną wokół niej.',
    pillars: [
      ['📰 Redakcja newsowa', 'CuloScribe, nasz redaktor AI, pobiera RSS-y z głównych publikacji o ekosystemie TON, odsiewa to co już opisaliśmy, i opowiada każdą historię własnymi słowami w czterech językach (EN/RU/PL/DE). Około 24 newsy dziennie plus trzy redakcyjne podsumowania (rano, południe, wieczór), które syntetyzują dany odcinek w jednym tekście.'],
      ['🤖 Bot Telegramowy', '@cscriber_bot żyje na naszym czacie t.me/culoton. /news daje ostatnie 6h newsów. /price culoton pobiera dane rynkowe z GeckoTerminal na żywo. /ask odpowiada przez Claude Haiku z ostatnimi 50 newsami EN jako kontekstem. /points i /leaderboard śledzą aktywność, a dzienny /quiz spada o 17:00 czasu polskiego.'],
      ['🏆 Tygodniowa pula nagród', 'Najaktywniejszy członek tygodnia dostaje 5 TON, wypłacane w każdą niedzielę o 20:00 UTC. Aktywność = posty, wygrane quizy, użycie /ask, ranking. Bez farmienia — limit 20 punktów na osobę dziennie.'],
      ['📡 Publikacja wielokanałowa', 'Każda historia leci automatycznie na Telegram (@culoton) i X (@culoton_). Market pulse dla $CULOTON wychodzi 4× dziennie na obu kanałach, dane z GeckoTerminal. Trzy podsumowania dziennie lądują na blogu culoton.fun/blog.'],
      ['💎 Token $CULOTON', 'Jetton na TON bez TAX, kontrakt EQAYaqIikry…b0A2Uc. Token jest brandowym ramieniem platformy — nie jest papierem wartościowym ani produktem yieldowym. Holderzy dostają tę samą treść co wszyscy, a projekt finansuje rozwój z aktywności po stronie tokenu.'],
    ],
    closer: 'Wszystko wychodzi z jednego repo GitHub, na cronie. Astro statyczne, Python ingest, Claude Haiku rewrites, GitHub Actions schedule, deploy FTP. Żadnych modów, żadnych shillerów, żadnych obietnic poza łańcuchem — kod otwarty na github.com/CuloTon.',
  },
  ru: {
    h: 'Как работает система CULO TON',
    intro: 'CULO TON — это две вещи в одной связке: редакция новостей об экосистеме TON и tax-free мем-коин в её центре. Ради редакции люди приходят; токен её финансирует и вознаграждает сообщество, которое строится вокруг.',
    pillars: [
      ['📰 Редакция', 'CuloScribe, наш AI-редактор, забирает RSS из основных публикаций об экосистеме TON, отсеивает уже освещённое и пересказывает каждую историю своим голосом на четырёх языках (EN/RU/PL/DE). Около 24 новостей в день плюс три редакционных дайджеста (утро, полдень, вечер), синтезирующих период в один материал.'],
      ['🤖 Telegram-бот', '@cscriber_bot живёт в чате t.me/culoton. /news — последние 6ч новостей. /price culoton — рыночные данные с GeckoTerminal в реальном времени. /ask отвечает через Claude Haiku с последними 50 EN-новостями как контекстом. /points и /leaderboard отслеживают активность, ежедневный /quiz выпадает в 17:00 по польскому времени.'],
      ['🏆 Еженедельный призовой фонд', 'Самый активный участник недели получает 5 TON, выплата каждое воскресенье в 20:00 UTC. Активность = посты, победы в квизах, использование /ask, подъём в рейтинге. Без фарма — лимит 20 очков на человека в день.'],
      ['📡 Публикация по каналам', 'Каждая история автоматически уходит в Telegram (@culoton) и X (@culoton_). Market pulse $CULOTON выходит 4 раза в день на обоих каналах, данные с GeckoTerminal. Три дайджеста в день оседают в блоге culoton.fun/blog.'],
      ['💎 Токен $CULOTON', 'Jetton на TON без TAX, контракт EQAYaqIikry…b0A2Uc. Токен — это бренд-нога платформы, не ценная бумага и не yield-продукт. Холдеры получают тот же контент, что и все, а проект финансирует разработку через активность вокруг токена.'],
    ],
    closer: 'Всё выходит из одного GitHub-репозитория, по cron. Astro static, Python ingest, Claude Haiku rewrites, GitHub Actions schedule, FTP deploy. Без модов, без шиллеров, без обещаний вне цепочки — код открыт на github.com/CuloTon.',
  },
  de: {
    h: 'Wie das CULO TON System funktioniert',
    intro: 'CULO TON ist zweierlei, eng gekoppelt: eine Nachrichtenredaktion für das TON-Ökosystem und ein steuerfreier Memecoin in ihrer Mitte. Wegen der Redaktion kommen die Leute; der Token finanziert die Redaktion und belohnt die Community, die sich darum bildet.',
    pillars: [
      ['📰 Die Redaktion', 'CuloScribe, unser KI-Redakteur, liest RSS-Feeds der wichtigsten TON-Publikationen, dedupliziert bereits Behandeltes und erzählt jede Story in eigener Stimme über vier Sprachen (EN/RU/PL/DE). Etwa 24 News am Tag plus drei redaktionelle Roundups (Morgen, Mittag, Abend), die den Zeitraum in einen Text bündeln.'],
      ['🤖 Der Telegram-Bot', '@cscriber_bot lebt im Chat t.me/culoton. /news liefert die News der letzten 6h. /price culoton zieht live Marktdaten von GeckoTerminal. /ask antwortet via Claude Haiku mit den letzten 50 EN-News als Kontext. /points und /leaderboard tracken Aktivität, das tägliche /quiz fällt um 17:00 PL.'],
      ['🏆 Wöchentlicher Preispool', 'Das aktivste Mitglied jede Woche erhält 5 TON, ausgezahlt jeden Sonntag um 20:00 UTC. Aktivität = Posts, Quiz-Siege, /ask-Nutzung, Leaderboard-Aufstieg. Kein Farming — Cap bei 20 Punkten pro Person und Tag.'],
      ['📡 Cross-Channel-Publishing', 'Jede Story geht automatisch an Telegram (@culoton) und X (@culoton_). $CULOTON-Marktimpulse 4× täglich auf beiden Kanälen, Daten live von GeckoTerminal. Drei Roundups pro Tag landen im Blog auf culoton.fun/blog.'],
      ['💎 Der $CULOTON-Token', 'Steuerfreies TON-Jetton, Vertrag EQAYaqIikry…b0A2Uc. Der Token ist das Brand-Bein der Plattform — kein Wertpapier und kein Yield-Produkt. Halter bekommen denselben Content wie alle, und das Projekt finanziert die Entwicklung über Token-seitige Aktivität.'],
    ],
    closer: 'Alles läuft aus einem GitHub-Repo per Cron. Astro Static Site, Python-Ingest, Claude Haiku Rewrites, GitHub Actions Schedule, FTP-Deploy. Keine Mods, keine Shiller, keine Off-Chain-Versprechen — Code offen auf github.com/CuloTon.',
  },
} as const;
const how = HOW[locale];

const CTAX_TXT = {
  en: {
    kicker: 'Companion token',
    h: '$CTAX — the tax-bearing twin',
    intro: 'Alongside $CULOTON, the project also runs a small companion jetton called $CTAX (CuloTax). Where $CULOTON is the tax-free brand token meant to move freely, $CTAX is the tax-bearing counterpart: every trade pays a fee, and half of every fee flows straight back to existing holders.',
    tax_h: 'Tax mechanics',
    tax_rows: [
      ['25%', 'on every buy', 'paid to the contract by the buyer'],
      ['15%', 'on every sell', 'paid to the contract by the seller'],
      ['50%', 'of all taxes', 'redistributed to existing holders — the longer you hold, the more your share compounds'],
    ],
    locked_h: 'Already locked',
    locked_p: 'Ownership is renounced — admin address is the null address (0:0…0). The token cannot be re-minted, the tax cannot be changed, the metadata cannot be edited. Supply is hard-capped on-chain at 100,000,000,000 $CTAX. What you see is what stays.',
    why_h: 'Why two tokens?',
    why_p: '$CULOTON stays clean for transfers, tipping, listings on no-tax DEX routes. $CTAX captures the trader flow — every speculative buy or sell strengthens long-term holders. Two tokens, two roles, one ecosystem.',
    cta_view: 'View on tonviewer',
    cta_chart: 'Chart on GeckoTerminal',
    contract_label: 'CTAX contract',
  },
  pl: {
    kicker: 'Token towarzyszący',
    h: '$CTAX — bliźniak z taksem',
    intro: 'Obok $CULOTON projekt prowadzi też mały token towarzyszący — $CTAX (CuloTax). Jeśli $CULOTON to brandowy token bez TAX, który ma chodzić swobodnie, to $CTAX jest jego odpowiednikiem z TAX-em: każda transakcja płaci prowizję, a połowa każdej prowizji wraca prosto do dotychczasowych holderów.',
    tax_h: 'Mechanika TAX',
    tax_rows: [
      ['25%', 'od każdego kupna', 'płaci kupujący do kontraktu'],
      ['15%', 'od każdej sprzedaży', 'płaci sprzedający do kontraktu'],
      ['50%', 'całego TAX-u', 'rozdzielane między aktualnych holderów — im dłużej trzymasz, tym bardziej twoja część się składa'],
    ],
    locked_h: 'Już zablokowany',
    locked_p: 'Własność zrzeczona — admin to adres zerowy (0:0…0). Tokena nie można domintować, TAX-u nie da się zmienić, metadanych edytować. Supply jest hard-capowane on-chain na 100 000 000 000 $CTAX. Co widzisz, to zostaje.',
    why_h: 'Po co dwa tokeny?',
    why_p: '$CULOTON zostaje czysty do transferów, tippingu, listingów na trasach DEX bez TAX-u. $CTAX wyłapuje ruch traderski — każdy spekulacyjny zakup czy sprzedaż wzmacnia długoterminowych holderów. Dwa tokeny, dwie role, jeden ekosystem.',
    cta_view: 'Zobacz na tonviewer',
    cta_chart: 'Wykres na GeckoTerminal',
    contract_label: 'Kontrakt CTAX',
  },
  ru: {
    kicker: 'Токен-компаньон',
    h: '$CTAX — близнец с налогом',
    intro: 'Помимо $CULOTON у проекта есть небольшой токен-компаньон — $CTAX (CuloTax). Если $CULOTON — это бренд-токен без налога, который должен ходить свободно, то $CTAX — его налоговый двойник: каждая сделка платит комиссию, и половина каждой комиссии возвращается прямо к текущим холдерам.',
    tax_h: 'Механика налога',
    tax_rows: [
      ['25%', 'с каждой покупки', 'платит покупатель в контракт'],
      ['15%', 'с каждой продажи', 'платит продавец в контракт'],
      ['50%', 'всего налога', 'раздаётся существующим холдерам — чем дольше держишь, тем больше твоя доля компаундится'],
    ],
    locked_h: 'Уже залочен',
    locked_p: 'Владение отказано — admin это нулевой адрес (0:0…0). Токен нельзя домятить, налог нельзя изменить, метаданные нельзя редактировать. Supply жёстко зафиксирован on-chain на 100 000 000 000 $CTAX. Что видишь, то и остаётся.',
    why_h: 'Зачем два токена?',
    why_p: '$CULOTON остаётся чистым для трансферов, чаевых, листингов на маршрутах DEX без налога. $CTAX ловит трейдерский поток — каждая спекулятивная покупка или продажа усиливает долгосрочных холдеров. Два токена, две роли, одна экосистема.',
    cta_view: 'Смотреть на tonviewer',
    cta_chart: 'График на GeckoTerminal',
    contract_label: 'Контракт CTAX',
  },
  de: {
    kicker: 'Companion-Token',
    h: '$CTAX — der besteuerte Zwilling',
    intro: 'Neben $CULOTON betreibt das Projekt auch einen kleinen Companion-Token namens $CTAX (CuloTax). Während $CULOTON der steuerfreie Marken-Token ist, der frei laufen soll, ist $CTAX das besteuerte Gegenstück: jeder Trade zahlt eine Gebühr, und die Hälfte jeder Gebühr fließt direkt zurück an bestehende Halter.',
    tax_h: 'Steuermechanik',
    tax_rows: [
      ['25%', 'auf jeden Kauf', 'vom Käufer an den Kontrakt'],
      ['15%', 'auf jeden Verkauf', 'vom Verkäufer an den Kontrakt'],
      ['50%', 'aller Steuern', 'an bestehende Halter umverteilt — je länger du hältst, desto stärker compoundet dein Anteil'],
    ],
    locked_h: 'Bereits gesperrt',
    locked_p: 'Ownership ist abgegeben — Admin-Adresse ist die Null-Adresse (0:0…0). Der Token kann nicht nachgemintet, die Steuer nicht geändert, die Metadaten nicht bearbeitet werden. Supply ist on-chain hart auf 100.000.000.000 $CTAX gedeckelt. Was du siehst, bleibt.',
    why_h: 'Warum zwei Token?',
    why_p: '$CULOTON bleibt sauber für Transfers, Tipping, Listings auf steuerfreien DEX-Routen. $CTAX fängt den Trader-Flow ein — jeder spekulative Kauf oder Verkauf stärkt langfristige Halter. Zwei Token, zwei Rollen, ein Ökosystem.',
    cta_view: 'Auf tonviewer ansehen',
    cta_chart: 'Chart auf GeckoTerminal',
    contract_label: 'CTAX-Kontrakt',
  },
} as const;
const ctaxTxt = CTAX_TXT[locale];
---

<Layout
  locale={locale}
  pathWithoutLocale="/culo"
  title={t.culo_title}
  description={t.culo_meta_description}
>
  <article class="news-article">
    <div style="text-align: center; margin-bottom: 28px;">
      <img src="/culo.png" alt="$CULOTON token" style="width: 140px; height: 140px; border-radius: 50%; border: 3px solid var(--accent); margin: 0 auto;" />
    </div>

    <h1 style="text-align: center;"><span style="color: var(--accent); font-family: var(--font-mono);">$CULOTON</span></h1>

    <p class="article-summary" style="text-align: center; border-left: none; padding-left: 0;">
      {t.culo_summary}
    </p>

    <div class="ton-cta-row">
      <a class="cta-btn cta-primary" href={TELEGRAM} target="_blank" rel="noopener noreferrer">
        {t.culo_cta_join}
      </a>
      <a class="cta-btn cta-secondary" href={`https://tonviewer.com/${CONTRACT}`} target="_blank" rel="noopener noreferrer">
        {t.culo_cta_view}
      </a>
    </div>

    <div class="contract-box">
      <span class="contract-label">{t.culo_contract_label}</span>
      <code class="contract-value" id="contract-value">{CONTRACT}</code>
      <button class="copy-btn" type="button" id="copy-btn" data-value={CONTRACT} data-label-copy={t.culo_copy} data-label-copied={t.culo_copied} data-label-failed={t.culo_copy_failed}>{t.culo_copy}</button>
    </div>

    <div class="body">
      <h2 style="font-size: 22px; margin-top: 36px; color: var(--accent);">{t.culo_understanding_h}</h2>

      <p set:html={t.culo_understanding_p1_html} />
      <p set:html={t.culo_understanding_p2_html} />

      <h2 style="font-size: 22px; margin-top: 36px; color: var(--accent);">{how.h}</h2>
      <p>{how.intro}</p>
      <ul class="how-pillars">
        {how.pillars.map(([title, body]) => (
          <li>
            <strong>{title}</strong>
            <p>{body}</p>
          </li>
        ))}
      </ul>
      <p style="font-size: 14px; color: var(--text-mute); margin-top: 12px;">{how.closer}</p>

      <h2 style="font-size: 22px; margin-top: 36px; color: var(--accent);">{t.culo_track_h}</h2>
      <ul class="track-record">
        <li set:html={t.culo_track_li1_html} />
        <li set:html={t.culo_track_li2_html} />
        <li set:html={t.culo_track_li3_html} />
      </ul>

      <h2 style="font-size: 22px; margin-top: 36px; color: var(--accent);">{t.culo_why_h}</h2>
      <p>{t.culo_why_p}</p>

      <h2 style="font-size: 22px; margin-top: 36px; color: var(--accent);">{t.culo_community_h}</h2>
      <p set:html={t.culo_community_p_html} />

      <h2 style="font-size: 22px; margin-top: 36px; color: var(--accent);">{t.culo_disclaimer_h}</h2>
      <p style="font-size: 14px; color: var(--text-mute);">
        {t.culo_disclaimer_p}
      </p>

      <section class="ctax-block">
        <header class="ctax-head">
          <img src={CTAX_IMG} alt="$CTAX token" class="ctax-img" loading="lazy" />
          <div>
            <span class="ctax-kicker">{ctaxTxt.kicker}</span>
            <h2 class="ctax-h">{ctaxTxt.h}</h2>
          </div>
        </header>
        <p class="ctax-intro">{ctaxTxt.intro}</p>

        <h3 class="ctax-sub">{ctaxTxt.tax_h}</h3>
        <div class="ctax-tax-grid">
          {ctaxTxt.tax_rows.map(([pct, when, note]) => (
            <div class="tax-cell">
              <span class="tax-pct">{pct}</span>
              <span class="tax-when">{when}</span>
              <span class="tax-note">{note}</span>
            </div>
          ))}
        </div>

        <div class="ctax-locked">
          <span class="locked-pill">🔒 {ctaxTxt.locked_h}</span>
          <p>{ctaxTxt.locked_p}</p>
        </div>

        <h3 class="ctax-sub">{ctaxTxt.why_h}</h3>
        <p class="ctax-why">{ctaxTxt.why_p}</p>

        <div class="contract-box ctax-contract-box">
          <span class="contract-label">{ctaxTxt.contract_label}</span>
          <code class="contract-value" id="ctax-contract-value">{CTAX_CONTRACT}</code>
          <button class="copy-btn" type="button" id="ctax-copy-btn" data-value={CTAX_CONTRACT} data-label-copy={t.culo_copy} data-label-copied={t.culo_copied} data-label-failed={t.culo_copy_failed}>{t.culo_copy}</button>
        </div>

        <div class="ton-cta-row" style="margin-top: 14px;">
          <a class="cta-btn cta-secondary" href={`https://tonviewer.com/${CTAX_CONTRACT}`} target="_blank" rel="noopener noreferrer">
            {ctaxTxt.cta_view}
          </a>
          <a class="cta-btn cta-secondary" href={`https://www.geckoterminal.com/ton/tokens/${CTAX_CONTRACT}`} target="_blank" rel="noopener noreferrer">
            {ctaxTxt.cta_chart}
          </a>
        </div>
      </section>
    </div>
  </article>
</Layout>

<style>
  .ton-cta-row {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
    margin: 24px 0 12px;
  }
  .cta-btn {
    display: inline-block;
    padding: 12px 22px;
    border-radius: 8px;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: 0.02em;
    transition: transform 0.12s, opacity 0.12s;
  }
  .cta-btn:hover { transform: translateY(-1px); opacity: 0.92; }
  .cta-primary { background: var(--accent); color: #1a1408 !important; }
  .cta-secondary {
    background: transparent;
    border: 1px solid var(--ton);
    color: var(--ton) !important;
  }

  .contract-box {
    margin: 18px auto 0;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px 16px;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    max-width: 760px;
  }
  .contract-label {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-mute);
    flex-shrink: 0;
  }
  .contract-value {
    flex: 1;
    min-width: 200px;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--text);
    word-break: break-all;
    background: transparent;
    padding: 0;
  }
  .copy-btn {
    background: var(--accent);
    color: #1a1408;
    border: none;
    padding: 6px 14px;
    border-radius: 5px;
    font-size: 12px;
    font-weight: 700;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .copy-btn:hover { opacity: 0.9; }
