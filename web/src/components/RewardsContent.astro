const t = I18N[locale] ?? I18N.en;

// --- Payout history (built at build time from data/rewards_rounds.json) ------
const rounds = roundsData.rounds ?? [];
const hasRounds = rounds.length > 0;
const totalPaid = roundsData.total_paid_ton ?? 0;
const roundsCount = roundsData.rounds_count ?? rounds.length;
const latestRound = hasRounds ? rounds[rounds.length - 1] : null;
const rollingCount = latestRound ? latestRound.rollover.length : 0;
const TONVIEWER = 'https://tonviewer.com/';
const fmtTon = (n: number) => Number(n).toFixed(3);
const shortAddr = (a: string) => (a.length > 14 ? a.slice(0, 6) + '…' + a.slice(-4) : a);
// Prefer the human-readable UQ.. form (address_uf) over raw 0:hex for display + links.
const addrOf = (h: any) => (h.address_uf ?? h.address);
const roundDate = (iso: string) => (iso || '').slice(0, 10);
const sharePct = (ton: number, total: number) => (total > 0 ? ((ton / total) * 100).toFixed(1) : '0.0');
// newest round first for display
const roundsView = [...rounds].reverse();

// --- Reward simulation (built from data/rewards_simulation.json) --------------
// Pre-computed by brt-nagrody/scripts/rewards_snapshot.py from the CURRENT holder
// distribution. Empty until the first snapshot runs.
const simLevels = (simData as any).levels ?? [];
const hasSim = simLevels.length > 0;
const simEligible = (simData as any).n_eligible ?? 0;
const simBased = t.sim_based.replace('%N%', String(simEligible));
const fmtTon2 = (n: number) => Number(n).toFixed(2);
---

<article class="rewards-page">
  <header class="rw-hero">
    <span class="kicker">{t.kicker}</span>
    <h1>{t.h1}</h1>
    <p class="lede">{t.lede}</p>
  </header>

  <div class="rw-stats">
    <div class="rw-stat">
      <span class="rw-stat-label">{t.stat_bank}</span>
      <span class="rw-stat-val" id="rw-bank">{t.loading}</span>
    </div>
    <div class="rw-stat rw-stat-accent">
      <span class="rw-stat-label">{t.stat_pool}</span>
      <span class="rw-stat-val" id="rw-pool">{t.loading}</span>
    </div>
    <div class="rw-stat">
      <span class="rw-stat-label">{t.stat_cadence}</span>
      <span class="rw-stat-val">{t.cadence_value}</span>
    </div>
  </div>

  <p class="rw-trigger">{t.trigger_note}</p>

  <section class="rw-history">
    <h2>{t.hist_h2}</h2>
    <p class="rw-hist-lede">{t.hist_lede}</p>

    {hasRounds ? (
      <>
        <div class="rw-hist-summary">
          <div class="rw-hsum"><span class="rw-hsum-val">{fmtTon(totalPaid)} TON</span><span class="rw-hsum-lbl">{t.hist_total}</span></div>
          <div class="rw-hsum"><span class="rw-hsum-val">{roundsCount}</span><span class="rw-hsum-lbl">{t.hist_rounds}</span></div>
          <div class="rw-hsum"><span class="rw-hsum-val">{rollingCount}</span><span class="rw-hsum-lbl">{t.hist_rolling}</span></div>
        </div>

        {roundsView.map((r) => (
          <div class="rw-round">
            <div class="rw-round-head">
              <span class="rw-round-no">{t.hist_round} #{r.round}</span>
              <span class="rw-round-date">{roundDate(r.at)}</span>
              <span class="rw-round-tot">{fmtTon(r.total_paid_ton)} TON · {r.paid.length} {t.hist_holders}</span>
            </div>

            <div class="rw-sub">{t.hist_paidto}</div>
            <ol class="rw-rank">
              {r.paid.map((h, i) => (
                <li class={h.top10 ? 'rw-rank-top10' : ''}>
                  <span class="rw-rank-n">{i + 1}</span>
                  <a class="rw-rank-addr" href={TONVIEWER + addrOf(h)} target="_blank" rel="noopener noreferrer">{shortAddr(addrOf(h))}</a>
                  {h.top10 && <span class="rw-top10-badge" title={t.hist_top10_badge}>★</span>}
                  <span class="rw-rank-pct">{sharePct(h.ton, r.total_paid_ton)}%</span>
                  <span class="rw-rank-ton">{fmtTon(h.ton)} TON</span>
                </li>
              ))}
            </ol>

            {r.rollover.length > 0 && (
              <>
                <div class="rw-sub rw-sub-roll">{t.hist_rollover}</div>
                <ul class="rw-rolllist">
                  {r.rollover.map((h) => (
                    <li>
                      <a class="rw-rank-addr" href={TONVIEWER + addrOf(h)} target="_blank" rel="noopener noreferrer">{shortAddr(addrOf(h))}</a>
                      <span class="rw-roll-ton">{fmtTon(h.ton)} TON {t.hist_pending}</span>
                    </li>
                  ))}
                </ul>
              </>
            )}
          </div>
        ))}
      </>
    ) : (
      <p class="rw-hist-none">{t.hist_none}</p>
    )}
  </section>

  <section class="rw-block">
    <h2>{t.how_h2}</h2>
    <ol class="rw-steps">
      {t.steps.map((s, i) => (
        <li>
          <span class="rw-n">{i + 1}</span>
          <div><strong>{s.t}</strong><p>{s.p}</p></div>
        </li>
      ))}
    </ol>
  </section>

  <section class="rw-top10">
    <span class="rw-top10-tag">★ TOP 10 · 25% + 25%</span>
    <h3>{t.top10_h3}</h3>
    <p>{t.top10_p}</p>
  </section>

  {hasSim && (
    <section class="rw-sim">
      <h2>{t.sim_h2}</h2>
      <p class="rw-sim-lede">{t.sim_lede}</p>
      <p class="rw-sim-based">{simBased}</p>
      <div class="rw-sim-table">
        <div class="rw-sim-row rw-sim-head">
          <span>{t.sim_bank}</span>
          <span>{t.sim_holders_lbl}</span>
          <span>{t.sim_top1_lbl}</span>
        </div>
        {simLevels.map((lv: any) => {
          const top1 = (lv.top && lv.top[0]) || null;
          return (
            <div class="rw-sim-row">
              <span class="rw-sim-bank">{fmtTon2(lv.bank)} TON</span>
              <span class="rw-sim-holders">
                {fmtTon2(lv.holders_pool_ton)} TON
                <em>{fmtTon2(lv.all_pool_ton)} {t.hist_pool_all} + {fmtTon2(lv.top10_pool_ton)} {t.hist_pool_top10}</em>
              </span>
              <span class="rw-sim-top1">
                {top1 ? <><b>{fmtTon(top1.ton)} TON</b><em>{fmtTon(top1.ton_all)} + {fmtTon(top1.ton_top10)} ★</em></> : '—'}
              </span>
            </div>
          );
        })}
      </div>
      <p class="rw-sim-note">{t.sim_note}</p>
    </section>
  )}

  <section class="rw-callout">
    <h3>{t.roll_h3}</h3>
    <p>{t.roll_p}</p>
  </section>

  <section class="rw-block rw-gas">
    <h3>{t.gas_h3}</h3>
    <p>{t.gas_p}</p>
  </section>

  <section class="rw-verify">
    <h3>{t.verify_h3}</h3>
    <div class="rw-links">
      <a href={DEV_TONVIEWER} target="_blank" rel="noopener noreferrer">{t.link_bank}</a>
      <a href={HOLDERS_TONVIEWER} target="_blank" rel="noopener noreferrer">{t.link_holders}</a>
      <a href={CONTRACT_TONVIEWER} target="_blank" rel="noopener noreferrer">{t.link_contract}</a>
    </div>
  </section>

  <p class="rw-disclaimer">{t.disclaimer}</p>
</article>

<script define:vars={{ DEV_ADDRESS, HOLDER_PCT }}>
  (function () {
    var bankEl = document.getElementById('rw-bank');
    var poolEl = document.getElementById('rw-pool');
    fetch('https://tonapi.io/v2/accounts/' + DEV_ADDRESS, { credentials: 'omit' })
      .then(function (r) { if (!r.ok) throw new Error('http ' + r.status); return r.json(); })
      .then(function (j) {
        var ton = Number(j.balance || 0) / 1e9;
        bankEl.textContent = ton.toFixed(2) + ' TON';
        // Holders' share = 50% total (25% all-holders pool + 25% top-10 pool).
        poolEl.textContent = (ton * HOLDER_PCT / 100).toFixed(3) + ' TON';
      })
      .catch(function () { bankEl.textContent = '—'; poolEl.textContent = '—'; });
  })();
</script>

