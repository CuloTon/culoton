---
// $BRT holder-rewards explainer. Live "bank" balance is read client-side from
// tonapi (read-only, public). All amounts/rules mirror scripts/rewards_snapshot.py.
import { localizedPath, type Locale } from '../i18n/strings';

interface Props { locale: Locale }
const { locale } = Astro.props;

