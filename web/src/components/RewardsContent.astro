      { t: `Щотижневий знімок`, p: `Раз на тиждень ми читаємо повний список холдерів $BRT та їхні баланси прямо з мережі.` },
      { t: `25% стають пулом`, p: `Чверть TON-балансу банку в цей момент утворює пул винагород. Решта — після того як 1 TON лишається в банку як буфер — ділиться 50/50 між гаманцями BRAINROT Invest і BRAINROT Marketing на розвиток.` },
      { t: `Поділ пропорційно`, p: `Пул ділиться за тим, скільки $BRT тримає гаманець. Тримаєш 2% придатної пропозиції — отримуєш 2% пулу.` },
      { t: `Лише справжні холдери`, p: `Пул ліквідності (DeDust), гаманець проєкту й адреса спалення виключені — вони ніколи не отримують винагороди. Рахуються лише справжні гаманці холдерів.` },
    ],
    roll_h3: `Мінімум 0,05 TON і перенесення`,
    roll_p: `Якщо твоя тижнева частка виходить менше 0,05 TON, вона поки не надсилається — газ мережі коштував би дорожче, ніж вона. Натомість вона переноситься: твої $BRT далі рахуються, і коли банк росте (або ти тримаєш більше) частка переходить 0,05 TON і тобі платять. Нічого не втрачається — малі частки просто накопичуються, доки їх не варто надіслати.`,
    gas_h3: `Ти отримуєш повну частку`,
    gas_p: `Холдери отримують повну частку в TON; газ мережі доплачує проєкт. З твоєї винагороди не знімається жодна комісія.`,
    disclaimer: `$BRT — це спільнотний мемкоїн, а не інвестиція. Винагороди повністю залежать від того, скільки проєкт реально заробляє — вони можуть бути нульовими. Це не фінансова порада і не обіцянка прибутку. Тримай $BRT тому що тобі подобається проєкт, а не заради очікуваної дохідності.`,
    verify_h3: `Перевір on-chain`, link_bank: `Гаманець банку винагород ↗`, link_holders: `Холдери $BRT ↗`, link_contract: `Контракт $BRT ↗`,
    hist_h2: `Усі виплачені нагороди TON`,
    hist_lede: `Кожен раунд виплат, on-chain і за пунктами: хто скільки отримав, за спаданням — плюс гаманці, які зараз переносяться до порогу 0,05 TON. Натисни будь-яку адресу, щоб відкрити її на Tonviewer.`,
    hist_total: `Усього виплачено`, hist_rounds: `Раунди`, hist_rolling: `Гаманці в перенесенні`,
    hist_round: `Раунд`, hist_holders: `холдерів`,
    hist_paidto: `Розподілено холдерам`, hist_rollover: `Перенесення — частка нижче 0,05 TON, накопичується`, hist_pending: `очікує`,
    hist_none: `Нагороди ще не виплачувалися. Перший раунд запуститься, коли банк перевищить 4 TON — зазирни згодом.`,
  },
};

const t = I18N[locale] ?? I18N.en;

// --- Payout history (built at build time from data/rewards_rounds.json) ------
const rounds = roundsData.rounds ?? [];
const hasRounds = rounds.length > 0;
const totalPaid = roundsData.total_paid_ton ?? 0;
const roundsCount = roundsData.rounds_count ?? rounds.length;
const latestRound = hasRounds ? rounds[rounds.length - 1] : null;
const rollingCount = latestRound ? latestRound.rollover.length : 0;
const TONVIEWER = 'https://tonviewer.com/';
const fmtTon = (n: number) => Number(n).toFixed(3);
const shortAddr = (a: string) => (a.length > 14 ? a.slice(0, 6) + '…' + a.slice(-4) : a);
const roundDate = (iso: string) => (iso || '').slice(0, 10);
const sharePct = (ton: number, total: number) => (total > 0 ? ((ton / total) * 100).toFixed(1) : '0.0');
// newest round first for display
const roundsView = [...rounds].reverse();
---

<article class="rewards-page">
  <header class="rw-hero">
    <span class="kicker">{t.kicker}</span>
    <h1>{t.h1}</h1>
    <p class="lede">{t.lede}</p>
  </header>

  <div class="rw-stats">
    <div class="rw-stat">
      <span class="rw-stat-label">{t.stat_bank}</span>
      <span class="rw-stat-val" id="rw-bank">{t.loading}</span>
    </div>
    <div class="rw-stat rw-stat-accent">
      <span class="rw-stat-label">{t.stat_pool}</span>
      <span class="rw-stat-val" id="rw-pool">{t.loading}</span>
    </div>
    <div class="rw-stat">
      <span class="rw-stat-label">{t.stat_cadence}</span>
      <span class="rw-stat-val">{t.cadence_value}</span>
    </div>
  </div>

  <p class="rw-trigger">{t.trigger_note}</p>

  <section class="rw-history">
    <h2>{t.hist_h2}</h2>
    <p class="rw-hist-lede">{t.hist_lede}</p>

    {hasRounds ? (
      <>
        <div class="rw-hist-summary">
          <div class="rw-hsum"><span class="rw-hsum-val">{fmtTon(totalPaid)} TON</span><span class="rw-hsum-lbl">{t.hist_total}</span></div>
          <div class="rw-hsum"><span class="rw-hsum-val">{roundsCount}</span><span class="rw-hsum-lbl">{t.hist_rounds}</span></div>
          <div class="rw-hsum"><span class="rw-hsum-val">{rollingCount}</span><span class="rw-hsum-lbl">{t.hist_rolling}</span></div>
        </div>

        {roundsView.map((r) => (
          <div class="rw-round">
            <div class="rw-round-head">
              <span class="rw-round-no">{t.hist_round} #{r.round}</span>
              <span class="rw-round-date">{roundDate(r.at)}</span>
              <span class="rw-round-tot">{fmtTon(r.total_paid_ton)} TON · {r.paid.length} {t.hist_holders}</span>
            </div>

            <div class="rw-sub">{t.hist_paidto}</div>
            <ol class="rw-rank">
              {r.paid.map((h, i) => (
                <li>
                  <span class="rw-rank-n">{i + 1}</span>
                  <a class="rw-rank-addr" href={TONVIEWER + h.address} target="_blank" rel="noopener noreferrer">{shortAddr(h.address)}</a>
                  <span class="rw-rank-pct">{sharePct(h.ton, r.total_paid_ton)}%</span>
                  <span class="rw-rank-ton">{fmtTon(h.ton)} TON</span>
                </li>
              ))}
            </ol>

            {r.rollover.length > 0 && (
              <>
                <div class="rw-sub rw-sub-roll">{t.hist_rollover}</div>
                <ul class="rw-rolllist">
                  {r.rollover.map((h) => (
                    <li>
                      <a class="rw-rank-addr" href={TONVIEWER + h.address} target="_blank" rel="noopener noreferrer">{shortAddr(h.address)}</a>
                      <span class="rw-roll-ton">{fmtTon(h.ton)} TON {t.hist_pending}</span>
                    </li>
                  ))}
                </ul>
              </>
            )}
          </div>
        ))}
      </>
    ) : (
      <p class="rw-hist-none">{t.hist_none}</p>
    )}
  </section>

  <section class="rw-block">
    <h2>{t.how_h2}</h2>
    <ol class="rw-steps">
      {t.steps.map((s, i) => (
        <li>
          <span class="rw-n">{i + 1}</span>
          <div><strong>{s.t}</strong><p>{s.p}</p></div>
        </li>
      ))}
    </ol>
  </section>

  <section class="rw-callout">
    <h3>{t.roll_h3}</h3>
    <p>{t.roll_p}</p>
  </section>

  <section class="rw-block rw-gas">
    <h3>{t.gas_h3}</h3>
    <p>{t.gas_p}</p>
  </section>

  <section class="rw-verify">
    <h3>{t.verify_h3}</h3>
    <div class="rw-links">
      <a href={DEV_TONVIEWER} target="_blank" rel="noopener noreferrer">{t.link_bank}</a>
      <a href={HOLDERS_TONVIEWER} target="_blank" rel="noopener noreferrer">{t.link_holders}</a>
      <a href={CONTRACT_TONVIEWER} target="_blank" rel="noopener noreferrer">{t.link_contract}</a>
    </div>
  </section>

  <p class="rw-disclaimer">{t.disclaimer}</p>
</article>

<script define:vars={{ DEV_ADDRESS, REWARD_PCT }}>
  (function () {
    var bankEl = document.getElementById('rw-bank');
    var poolEl = document.getElementById('rw-pool');
    fetch('https://tonapi.io/v2/accounts/' + DEV_ADDRESS, { credentials: 'omit' })
      .then(function (r) { if (!r.ok) throw new Error('http ' + r.status); return r.json(); })
      .then(function (j) {
        var ton = Number(j.balance || 0) / 1e9;
        bankEl.textContent = ton.toFixed(2) + ' TON';
        poolEl.textContent = (ton * REWARD_PCT / 100).toFixed(3) + ' TON';
      })
      .catch(function () { bankEl.textContent = '—'; poolEl.textContent = '—'; });
  })();
</script>

<style>
  .rewards-page { max-width: var(--maxw); margin: 0 auto; padding: 0 24px; }
  .rw-hero { margin: 32px 0 28px; padding-bottom: 26px; border-bottom: 1px solid var(--rule); }
  .kicker {
    display: inline-block; font-family: var(--font-mono); font-size: 11px;
    letter-spacing: 0.22em; text-transform: uppercase; color: #6dd4a8; margin-bottom: 18px;
  }
  .rw-hero h1 {
    margin: 0 0 16px; font-family: var(--font-display); font-weight: 800;
    font-size: clamp(38px, 6vw, 62px); line-height: 1.05; letter-spacing: -0.025em; color: #fff;
  }
  .rw-hero .lede {
    font-family: var(--font-serif); font-size: 20px; line-height: 1.55;
    color: var(--text-dim); margin: 0; max-width: 66ch;
  }
  .rw-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin: 0 0 40px; }
  .rw-stat {
    display: flex; flex-direction: column; gap: 8px; padding: 20px;
    background: var(--bg-section); border: 1px solid var(--rule); border-left: 2px solid var(--rule);
  }
  .rw-stat-accent { border-left-color: #6dd4a8; background: linear-gradient(180deg, rgba(109,212,168,0.08), transparent); }
  .rw-stat-label {
    font-family: var(--font-mono); font-size: 10px; text-transform: uppercase;
    letter-spacing: 0.14em; color: var(--text-mute);
  }
  .rw-stat-val { font-family: var(--font-mono); font-size: 26px; font-weight: 700; color: #fff; }
  .rw-stat-accent .rw-stat-val { color: #6dd4a8; }
  .rw-trigger {
    margin: -24px 0 40px; padding: 14px 18px; border-radius: 10px;
    background: rgba(255, 214, 10, 0.08); border: 1px solid rgba(255, 214, 10, 0.32);
    font-family: var(--font-mono); font-size: 13px; line-height: 1.6; color: #ffe9a8;
  }

  .rw-block { margin: 0 0 40px; }
  .rw-block h2 {
    font-family: var(--font-display); font-weight: 800; font-size: clamp(26px, 4vw, 36px);
    color: #fff; margin: 0 0 22px; letter-spacing: -0.02em;
  }
  .rw-steps { list-style: none; padding: 0; margin: 0; display: grid; gap: 14px; }
  .rw-steps li { display: flex; gap: 16px; padding: 18px 20px; background: var(--bg-section); border-left: 2px solid #6dd4a8; }
  .rw-n {
    flex-shrink: 0; width: 30px; height: 30px; display: flex; align-items: center; justify-content: center;
    border: 1px solid #6dd4a8; border-radius: 50%; color: #6dd4a8;
    font-family: var(--font-mono); font-size: 14px; font-weight: 700;
  }
  .rw-steps strong { display: block; color: #fff; font-family: var(--font-display); font-size: 18px; margin-bottom: 5px; }
  .rw-steps p { margin: 0; font-family: var(--font-serif); color: var(--text-dim); font-size: 16px; line-height: 1.6; }

  .rw-callout {
    margin: 0 0 40px; padding: 26px 28px; border-radius: 14px;
    background: linear-gradient(180deg, rgba(109,212,168,0.12), rgba(109,212,168,0.04));
    border: 1px solid rgba(109,212,168,0.4);
  }
  .rw-callout h3 { margin: 0 0 12px; font-family: var(--font-display); font-weight: 800; font-size: 22px; color: #aef0cf; }
  .rw-callout p { margin: 0; font-family: var(--font-serif); font-size: 17px; line-height: 1.65; color: var(--text-dim); }

  .rw-gas h3 { font-family: var(--font-display); font-weight: 800; font-size: 22px; color: #fff; margin: 0 0 10px; }
  .rw-gas p { margin: 0; font-family: var(--font-serif); font-size: 17px; line-height: 1.6; color: var(--text-dim); }

  .rw-verify { margin: 0 0 32px; }
  .rw-verify h3 {
    font-family: var(--font-mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.16em;
    color: var(--text-mute); margin: 0 0 14px;
  }
  .rw-links { display: flex; flex-wrap: wrap; gap: 10px 22px; }
  .rw-links a { font-family: var(--font-mono); font-size: 13px; color: #6dd4a8; text-decoration: none; border-bottom: 1px solid rgba(109,212,168,0.4); }
  .rw-links a:hover { color: #aef0cf; }

  .rw-disclaimer {
    margin: 0 0 64px; padding: 16px 20px; background: rgba(255,255,255,0.03);
    border: 1px solid var(--rule); color: var(--text-mute);
    font-family: var(--font-mono); font-size: 12px; line-height: 1.7;
  }

  /* ---- Payout history ---- */
  .rw-history { margin: 0 0 44px; }
  .rw-history h2 {
    font-family: var(--font-display); font-weight: 800; font-size: clamp(26px, 4vw, 36px);
    color: #fff; margin: 0 0 12px; letter-spacing: -0.02em;
  }
  .rw-hist-lede { margin: 0 0 22px; font-family: var(--font-serif); font-size: 16px; line-height: 1.6; color: var(--text-dim); max-width: 70ch; }
  .rw-hist-summary { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin: 0 0 28px; }
  .rw-hsum {
    display: flex; flex-direction: column; gap: 6px; padding: 18px 20px;
    background: var(--bg-section); border: 1px solid var(--rule); border-left: 2px solid #6dd4a8;
  }
  .rw-hsum-val { font-family: var(--font-mono); font-size: 24px; font-weight: 700; color: #6dd4a8; }
  .rw-hsum-lbl { font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--text-mute); }

  .rw-round { margin: 0 0 22px; padding: 20px; background: var(--bg-section); border: 1px solid var(--rule); border-radius: 10px; }
  .rw-round-head { display: flex; flex-wrap: wrap; align-items: baseline; gap: 8px 16px; padding-bottom: 14px; margin-bottom: 14px; border-bottom: 1px solid var(--rule); }
  .rw-round-no { font-family: var(--font-display); font-weight: 800; font-size: 18px; color: #fff; }
  .rw-round-date { font-family: var(--font-mono); font-size: 12px; color: var(--text-mute); }
  .rw-round-tot { margin-left: auto; font-family: var(--font-mono); font-size: 13px; color: #6dd4a8; }
  .rw-sub { font-family: var(--font-mono); font-size: 10px; text-transform: uppercase; letter-spacing: 0.14em; color: var(--text-mute); margin: 0 0 10px; }
  .rw-sub-roll { margin-top: 18px; color: #ffd24a; }

  .rw-rank { list-style: none; padding: 0; margin: 0; display: grid; gap: 4px; }
  .rw-rank li { display: flex; align-items: center; gap: 12px; padding: 8px 10px; border-radius: 6px; }
  .rw-rank li:nth-child(odd) { background: rgba(255,255,255,0.03); }
  .rw-rank-n {
    flex-shrink: 0; width: 22px; height: 22px; display: flex; align-items: center; justify-content: center;
    border-radius: 50%; background: rgba(109,212,168,0.14); color: #6dd4a8;
    font-family: var(--font-mono); font-size: 11px; font-weight: 700;
  }
  .rw-rank li:nth-child(1) .rw-rank-n { background: #ffd24a; color: #1a1a1a; }
  .rw-rank li:nth-child(2) .rw-rank-n { background: #d6d6d6; color: #1a1a1a; }
  .rw-rank li:nth-child(3) .rw-rank-n { background: #cd9b6a; color: #1a1a1a; }
  .rw-rank-addr { font-family: var(--font-mono); font-size: 13px; color: #6dd4a8; text-decoration: none; border-bottom: 1px solid rgba(109,212,168,0.35); }
  .rw-rank-addr:hover { color: #aef0cf; }
  .rw-rank-pct { font-family: var(--font-mono); font-size: 12px; color: var(--text-mute); }
  .rw-rank-ton { margin-left: auto; font-family: var(--font-mono); font-size: 13px; font-weight: 700; color: #fff; }

  .rw-rolllist { list-style: none; padding: 0; margin: 0; display: grid; gap: 4px; }
  .rw-rolllist li { display: flex; align-items: center; gap: 12px; padding: 7px 10px; }
  .rw-roll-ton { margin-left: auto; font-family: var(--font-mono); font-size: 12px; color: #ffd24a; }
  .rw-hist-none {
    margin: 0; padding: 18px 20px; background: rgba(255, 214, 10, 0.08);
    border: 1px solid rgba(255, 214, 10, 0.32); border-radius: 10px;
    font-family: var(--font-mono); font-size: 13px; line-height: 1.6; color: #ffe9a8;
  }

  @media (max-width: 600px) {
    .rw-stats { grid-template-columns: 1fr; }
    .rw-hero h1 { font-size: clamp(30px, 9vw, 40px); }
    .rw-hist-summary { grid-template-columns: 1fr; }
    .rw-round-tot { margin-left: 0; width: 100%; }
    .rw-rank-pct { display: none; }
  }
</style>
