---
interface Props {
  slug: string;
  title: string;
  summary: string;
  date: Date;
  source_name: string;
  tags: string[];
}

const { slug, title, summary, date, source_name, tags } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<article class="news-card">
  <span class="source">{source_name}</span>
  <h3><a href={`/news/${slug}`}>{title}</a></h3>
  <p>{summary}</p>
  <div class="footer-row">
    <div class="tags">
      {tags.slice(0, 3).map((t) => <span class="tag">{t}</span>)}
    </div>
    <time datetime={date.toISOString()}>{formattedDate}</time>
  </div>
</article>
