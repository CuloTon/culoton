---
import type { Locale } from '../i18n/strings';
import { DATE_LOCALE, localizedPath } from '../i18n/strings';

interface Props {
  locale: Locale;
  slug: string;
  title: string;
  summary: string;
  date: Date;
  source_name: string;
  tags: string[];
}

const { locale, slug, title, summary, date, source_name, tags } = Astro.props;

const formattedDate = date.toLocaleDateString(DATE_LOCALE[locale], {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const href = localizedPath(locale, `/news/${slug}`);
---

<article class="news-card">
  <span class="source">{source_name}</span>
  <h3><a href={href}>{title}</a></h3>
  <p>{summary}</p>
  <div class="footer-row">
    <div class="tags">
      {tags.slice(0, 3).map((t) => <span class="tag">{t}</span>)}
    </div>
    <time datetime={date.toISOString()}>{formattedDate}</time>
  </div>
</article>
