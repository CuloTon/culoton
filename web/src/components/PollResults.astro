---
interface Props {
  locale: 'en' | 'pl' | 'de' | 'ru' | 'es' | 'uk';
}

const { locale } = Astro.props;

const COPY = {
  en: {
    closed: 'Poll closed',
    final: 'Final tally',
    votes: 'votes',
    decision: 'Community decision',
    body: 'The community has spoken. After 38 votes, the winning tokenomics setup for $BRT is:',
    opt1: 'Buy tax',
    opt2: 'Sell tax',
    opt3: 'Holder rewards',
    optNote3: 'of all tax revenue distributed to $BRT holders',
    winner: 'WINNER',
    note: 'Vote is closed. The setup above will be reflected when the new $BRT contract launches.',
  },
  pl: {
    closed: 'Głosowanie zakończone',
    final: 'Wynik końcowy',
    votes: 'głosów',
    decision: 'Decyzja społeczności',
    body: 'Społeczność zdecydowała. Po 38 głosach, wygrywająca konfiguracja tokenomiki $BRT to:',
    opt1: 'Buy tax',
    opt2: 'Sell tax',
    opt3: 'Nagrody dla holderów',
    optNote3: 'całości wpływów z podatków trafia do holderów $BRT',
    winner: 'ZWYCIĘZCA',
    note: 'Głosowanie jest zamknięte. Powyższa konfiguracja zostanie wdrożona przy starcie nowego kontraktu $BRT.',
  },
  de: {
    closed: 'Abstimmung geschlossen',
    final: 'Endergebnis',
    votes: 'Stimmen',
    decision: 'Community-Entscheidung',
    body: 'Die Community hat entschieden. Nach 38 Stimmen ist das gewinnende Tokenomics-Setup für $BRT:',
    opt1: 'Kauf-Tax',
    opt2: 'Verkauf-Tax',
    opt3: 'Holder-Belohnungen',
    optNote3: 'des Tax-Aufkommens gehen an $BRT-Holder',
    winner: 'SIEGER',
    note: 'Die Abstimmung ist geschlossen. Das obige Setup wird beim Start des neuen $BRT-Vertrags umgesetzt.',
  },
  ru: {
    closed: 'Голосование закрыто',
    final: 'Итоговый результат',
    votes: 'голосов',
    decision: 'Решение сообщества',
    body: 'Сообщество высказалось. После 38 голосов победившая токеномика для $BRT:',
    opt1: 'Buy tax',
    opt2: 'Sell tax',
    opt3: 'Вознаграждение холдерам',
    optNote3: 'всех налоговых поступлений идут холдерам $BRT',
    winner: 'ПОБЕДИТЕЛЬ',
    note: 'Голосование закрыто. Конфигурация будет реализована при запуске нового контракта $BRT.',
  },
  es: {
    closed: 'Votación cerrada',
    final: 'Resultado final',
    votes: 'votos',
    decision: 'Decisión de la comunidad',
    body: 'La comunidad ha hablado. Tras 38 votos, la configuración ganadora de tokenomics para $BRT es:',
    opt1: 'Tax de compra',
    opt2: 'Tax de venta',
    opt3: 'Recompensas a holders',
    optNote3: 'de los ingresos por tax se distribuyen a holders de $BRT',
    winner: 'GANADOR',
    note: 'La votación está cerrada. La configuración se reflejará al lanzar el nuevo contrato $BRT.',
  },
  uk: {
    closed: 'Голосування закрите',
    final: 'Підсумок',
    votes: 'голосів',
    decision: 'Рішення спільноти',
    body: 'Спільнота висловилася. Після 38 голосів переможна токеноміка для $BRT:',
    opt1: 'Buy tax',
    opt2: 'Sell tax',
    opt3: 'Винагороди холдерам',
    optNote3: 'усіх надходжень з податків розподіляється холдерам $BRT',
    winner: 'ПЕРЕМОЖЕЦЬ',
    note: 'Голосування закрите. Конфігурація буде впроваджена при старті нового контракту $BRT.',
  },
};

const t = COPY[locale];
---

<section class="poll-results-card">
  <div class="poll-closed-badge">
    <span class="dot"></span>
    {t.closed}
  </div>
  <div class="poll-total">
    <span class="poll-total-num">38</span>
    <span class="poll-total-label">{t.votes}</span>
  </div>

  <p class="poll-body">{t.body}</p>

  <div class="poll-bars">
    <div class="poll-row">
      <div class="poll-row-head">
        <span class="poll-row-label">{t.opt1}</span>
        <span class="poll-row-num">25%</span>
      </div>
      <div class="poll-bar-track"><div class="poll-bar-fill" style="width:25%; background: linear-gradient(90deg, #6cb4ff, #b8a5ff);"></div></div>
    </div>

    <div class="poll-row">
      <div class="poll-row-head">
        <span class="poll-row-label">{t.opt2}</span>
        <span class="poll-row-num">25%</span>
      </div>
      <div class="poll-bar-track"><div class="poll-bar-fill" style="width:25%; background: linear-gradient(90deg, #6dd4a8, #6cb4ff);"></div></div>
    </div>

    <div class="poll-row poll-row-winner">
      <div class="poll-row-head">
        <span class="poll-row-label">
          <span class="winner-badge">🏆 {t.winner}</span>
          {t.opt3}
        </span>
        <span class="poll-row-num">50%</span>
      </div>
      <div class="poll-bar-track"><div class="poll-bar-fill" style="width:50%; background: linear-gradient(90deg, #ff6f6f, #ffb04a);"></div></div>
      <p class="poll-row-sub">{t.optNote3}</p>
    </div>
  </div>

  <p class="poll-note">{t.note}</p>
</section>

<style>
  .poll-results-card {
    background: #fff;
    border: 1px solid var(--rule, rgba(20, 20, 30, 0.08));
    border-radius: var(--radius-lg, 28px);
    padding: 40px 36px;
    box-shadow: var(--shadow-md, 0 8px 28px rgba(20, 20, 30, 0.06));
    margin: 28px auto 0;
    max-width: 780px;
  }

  .poll-closed-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 111, 111, 0.10);
    color: #d63838;
    padding: 6px 14px;
    border-radius: 999px;
    font-family: var(--font-mono, "JetBrains Mono", monospace);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }
  .poll-closed-badge .dot {
    width: 8px;
    height: 8px;
    background: #d63838;
    border-radius: 50%;
    animation: poll-pulse 2s ease-in-out infinite;
  }
  @keyframes poll-pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(214, 56, 56, 0.5); }
    50% { box-shadow: 0 0 0 6px rgba(214, 56, 56, 0); }
  }

  .poll-total {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 28px;
  }
  .poll-total-num {
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 900;
    font-size: clamp(56px, 8vw, 88px);
    letter-spacing: -0.03em;
    line-height: 1;
    background: linear-gradient(135deg, #ff6f6f 0%, #b8a5ff 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .poll-total-label {
    font-size: 18px;
    color: var(--text-mute, #6b7180);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .poll-body {
    font-size: 18px;
    color: var(--text-dim, #2d3142);
    line-height: 1.55;
    margin: 0 0 28px;
  }

  .poll-bars {
    display: flex;
    flex-direction: column;
    gap: 22px;
    margin-bottom: 28px;
  }
  .poll-row {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .poll-row-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
  }
  .poll-row-label {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 16px;
    font-weight: 700;
    color: var(--text, #1a1d29);
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }
  .poll-row-num {
    font-family: "Inter", system-ui, sans-serif;
    font-size: 22px;
    font-weight: 800;
    color: var(--text, #1a1d29);
    letter-spacing: -0.02em;
    font-variant-numeric: tabular-nums;
  }
  .poll-bar-track {
    height: 14px;
    background: rgba(20, 20, 30, 0.05);
    border-radius: 999px;
    overflow: hidden;
  }
  .poll-bar-fill {
    height: 100%;
    border-radius: 999px;
    transition: width 1s ease;
  }
  .poll-row-winner .poll-bar-track { height: 18px; }
  .poll-row-winner .poll-row-num { font-size: 28px; color: #d63838; }
  .poll-row-sub {
    font-size: 14px;
    color: var(--text-mute, #6b7180);
    margin: 4px 0 0;
    line-height: 1.45;
  }
  .winner-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: linear-gradient(135deg, #ff6f6f, #b8a5ff);
    color: #fff;
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 800;
    letter-spacing: 0.08em;
  }

  .poll-note {
    margin: 0;
    padding: 16px 20px;
    background: rgba(108, 180, 255, 0.10);
    border-left: 3px solid #6cb4ff;
    border-radius: 12px;
    font-size: 15px;
    color: var(--text-dim, #2d3142);
    line-height: 1.55;
  }

  @media (max-width: 600px) {
    .poll-results-card { padding: 28px 22px; border-radius: 20px; }
    .poll-total-num { font-size: 56px; }
    .poll-body { font-size: 16px; }
    .poll-row-label { font-size: 15px; }
    .poll-row-num { font-size: 20px; }
    .poll-row-winner .poll-row-num { font-size: 24px; }
  }
</style>
