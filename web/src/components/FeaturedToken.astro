---
import { UI, localizedPath, type Locale } from '../i18n/strings';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = UI[locale];
const TELEGRAM = 'https://t.me/culoton';
---

<aside class="featured-token">
  <img src="/culo.png" alt="$CULO token" />
  <div class="ft-text">
    <span class="pill">{t.featured_token_pill}</span>
    <h3 set:html={t.featured_token_h_html} />
    <p>{t.featured_token_p}</p>
  </div>
  <div class="ft-actions">
    <a href={localizedPath(locale, '/culo')} class="ft-btn-primary">{t.featured_token_btn_info}</a>
    <a href={TELEGRAM} target="_blank" rel="noopener noreferrer" class="ft-btn-secondary">{t.featured_token_btn_telegram}</a>
  </div>
</aside>

<style>
  .ft-actions {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .ft-btn-primary {
    background: var(--accent);
    color: #1a1408 !important;
    padding: 10px 18px;
    border-radius: 6px;
    font-weight: 700;
    font-size: 14px;
    text-align: center;
  }
  .ft-btn-secondary {
    background: transparent;
    border: 1px solid var(--text-dim);
    color: var(--text-dim) !important;
    padding: 9px 17px;
    border-radius: 6px;
    font-weight: 600;
    font-size: 13px;
    text-align: center;
  }
  .ft-btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent) !important;
  }
</style>
