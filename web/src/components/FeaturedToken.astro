---
import { UI, localizedPath, type Locale } from '../i18n/strings';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = UI[locale];
const TELEGRAM = 'https://t.me/culoton';
---

<aside class="featured-token">
  <img src="/culo.png" alt="$CULO token" />
  <div class="ft-text">
    <span class="pill">{t.featured_token_pill}</span>
    <h3 set:html={t.featured_token_h_html} />
    <p>{t.featured_token_p}</p>
  </div>
  <div class="ft-actions">
    <a href={localizedPath(locale, '/culo')} class="ft-btn-primary">{t.featured_token_btn_info}</a>
    <a href={TELEGRAM} target="_blank" rel="noopener noreferrer" class="ft-btn-secondary">{t.featured_token_btn_telegram}</a>
  </div>
</aside>

<style>
  .ft-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .ft-btn-primary,
  .ft-btn-secondary {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 11px 18px;
    border-radius: 0;
    text-align: center;
    border: 2px solid var(--accent);
    transition: background 0.12s, color 0.12s;
  }
  .ft-btn-primary {
    background: var(--accent);
    color: #1a1408 !important;
  }
  .ft-btn-primary:hover {
    background: transparent;
    color: var(--accent) !important;
  }
  .ft-btn-secondary {
    background: transparent;
    color: #fff8e0 !important;
    border-color: #4d4032;
  }
  .ft-btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent) !important;
  }
</style>
