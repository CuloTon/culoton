---
import { UI, localizedPath, type Locale } from '../i18n/strings';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = UI[locale];
const TELEGRAM = 'https://t.me/culoton';
---

<aside class="featured-token">
  <img src="/brainrot.png" alt="$BRT token" />
  <div class="ft-text">
    <span class="pill">{t.featured_token_pill}</span>
    <h3 set:html={t.featured_token_h_html} />
    <p>{t.featured_token_p}</p>
  </div>
  <div class="ft-actions">
    <a href={localizedPath(locale, '/culo')} class="ft-btn-primary">{t.featured_token_btn_info}</a>
    <a href={TELEGRAM} target="_blank" rel="noopener noreferrer" class="ft-btn-secondary">{t.featured_token_btn_telegram}</a>
  </div>
</aside>

<style>
  .ft-actions {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .ft-btn-primary,
  .ft-btn-secondary {
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 12px 22px;
    border-radius: 999px;
    text-align: center;
    transition: transform 0.18s, box-shadow 0.18s, background 0.18s, color 0.18s;
    border: 2px solid transparent;
  }
  .ft-btn-primary {
    background: var(--text);
    color: var(--bg) !important;
    box-shadow: 0 8px 24px rgba(20, 20, 30, 0.18);
  }
  .ft-btn-primary:hover {
    transform: translateY(-2px);
    background: var(--accent-text);
  }
  .ft-btn-secondary {
    background: #fff;
    color: var(--text) !important;
    border-color: var(--rule);
  }
  .ft-btn-secondary:hover {
    border-color: var(--accent);
    color: var(--accent-text) !important;
    transform: translateY(-2px);
  }
</style>
