---
import '../styles/global.css';
import '../styles/editorial.css';

interface Props { title?: string; description?: string; }
const { title = 'BRAINROT TAX', description = 'TON token TAX board — live charts, market cap, buy/sell/holders tax.' } = Astro.props;
const STATS_API = (import.meta.env.PUBLIC_STATS_API ?? '').toString().replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="stats-api" content={STATS_API} />
    <meta name="robots" content="noindex" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/brainrot.png?v=2" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Serif:ital,wght@0,400;0,600;0,700;0,800;1,400;1,700&family=IBM+Plex+Mono:wght@400;500;600;700&family=Archivo+Black&family=Space+Grotesk:wght@400;500;700&family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&display=swap"
    />
    <script src="https://telegram.org/js/telegram-web-app.js" is:inline></script>
    <style is:inline>
      html, body { background: #0b0b0d; margin: 0; }
      body { color: #e8eaee; -webkit-tap-highlight-color: transparent; }
      .tma-head { display: flex; align-items: center; gap: 10px; padding: 14px 18px 6px; }
      .tma-logo { width: 30px; height: 30px; border-radius: 8px; }
      .tma-title { font-family: var(--font-mono), monospace; font-size: 13px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: #7ae9b8; }
      .tma-sub { font-family: var(--font-mono), monospace; font-size: 10px; color: #8a909c; }
    </style>
  </head>
  <body>
    <div class="tma-head">
      <img class="tma-logo" src="/brainrot.png?v=2" alt="" />
      <div><div class="tma-title">BRAINROT · TAX</div><div class="tma-sub">live TON token board</div></div>
    </div>
    <slot />
    <script is:inline>
      (function () {
        var tg = window.Telegram && window.Telegram.WebApp;
        if (!tg) return;
        try {
          tg.ready();
          tg.expand();
          if (tg.setHeaderColor) tg.setHeaderColor('#0b0b0d');
          if (tg.setBackgroundColor) tg.setBackgroundColor('#0b0b0d');
        } catch (e) { /* ignore */ }
      })();
    </script>
  </body>
</html>
