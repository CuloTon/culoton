---
import '../styles/global.css';
import { UI, LOCALES, LOCALE_LABELS, LOCALE_FULL, HTML_LANG, localizedPath, type Locale } from '../i18n/strings';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  ogImage?: string;
  /** Path of the current page WITHOUT the locale prefix, e.g. '/' or '/about' or '/news/foo'. */
  pathWithoutLocale: string;
}

const {
  locale,
  title,
  description,
  ogImage = '/culo.png',
  pathWithoutLocale,
} = Astro.props;

const t = UI[locale];
const finalTitle = title ?? t.site_title;
const finalDescription = description ?? t.site_description;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();

const alternates = LOCALES.map((loc) => ({
  loc,
  href: new URL(localizedPath(loc, pathWithoutLocale), Astro.site).toString(),
}));
---

<!doctype html>
<html lang={HTML_LANG[locale]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href={canonical} />

    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.loc} href={a.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={alternates[0].href} />

    <title>{finalTitle}</title>
    <meta name="description" content={finalDescription} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={finalTitle} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:locale" content={locale === 'en' ? 'en_US' : `${locale}_${locale.toUpperCase()}`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={finalTitle} />
    <meta name="twitter:description" content={finalDescription} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Serif:ital,wght@0,400;0,600;0,700;0,800;1,400;1,700&family=IBM+Plex+Mono:wght@400;500;600;700&family=Archivo+Black&family=Space+Grotesk:wght@400;500;700&family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&display=swap"
    />

    <script is:inline>
      (function () {
        // Single live theme — terminal. Switcher widget is hidden in CSS.
        // Force-overwrite any prior localStorage value from when A/B/C/D/F were exposed.
        document.documentElement.setAttribute('data-theme', 'terminal');
        try { localStorage.setItem('culoton-theme', 'terminal'); } catch (_) {}
      })();
    </script>
  </head>
  <body>
    <header class="site-header" id="site-header">
      <div class="inner">
        <a href={localizedPath(locale, '/')} class="logo">
          <img src="/culo.png" alt="CuloTon logo" />
          <div>
            <span class="brand-culo">Culo</span><span class="brand-ton">Ton</span>
          </div>
          <span class="masthead-tag">— TON Desk</span>
        </a>
        <button
          type="button"
          class="hamburger"
          aria-label="Toggle navigation"
          aria-expanded="false"
          aria-controls="mobile-menu"
          id="hamburger-btn"
        >
          <span></span><span></span><span></span>
        </button>
        <div class="header-menu" id="mobile-menu">
          <nav class="main-nav">
            <a href={localizedPath(locale, '/')}>{t.nav_news}</a>
            <a href={localizedPath(locale, '/blog')}>{t.nav_blog}</a>
            <a href={localizedPath(locale, '/about')}>{t.nav_about}</a>
            <a href={localizedPath(locale, '/stonks')}>{t.nav_stonks}</a>
            <a href={localizedPath(locale, '/culo')}>{t.nav_token}</a>
          </nav>
          <div class="lang-switcher" aria-label="Language">
            {LOCALES.map((loc) => (
              <a
                href={localizedPath(loc, pathWithoutLocale)}
                class:list={["lang-link", { active: loc === locale }]}
                hreflang={loc}
                title={LOCALE_FULL[loc]}
              >{LOCALE_LABELS[loc]}</a>
            ))}
          </div>
          <div class="theme-switcher" role="radiogroup" aria-label="Theme">
            <button type="button" data-theme-set="magazine" title="A — Magazine">A</button>
            <button type="button" data-theme-set="memecoin" title="B — Memecoin">B</button>
            <button type="button" data-theme-set="minimal" title="C — Minimal">C</button>
            <button type="button" data-theme-set="memecoin-white" title="D — Memecoin White">D</button>
            <button type="button" data-theme-set="terminal" title="E — Terminal">E</button>
            <button type="button" data-theme-set="newspaper" title="F — Newspaper">F</button>
          </div>
        </div>
      </div>
    </header>
    <script is:inline>
      (function () {
        var btn = document.getElementById('hamburger-btn');
        var hdr = document.getElementById('site-header');
        if (btn && hdr) {
          btn.addEventListener('click', function () {
            var open = hdr.classList.toggle('menu-open');
            btn.setAttribute('aria-expanded', open ? 'true' : 'false');
          });
          document.querySelectorAll('#mobile-menu a').forEach(function (a) {
            a.addEventListener('click', function () {
              hdr.classList.remove('menu-open');
              btn.setAttribute('aria-expanded', 'false');
            });
          });
        }

        // Theme switcher: paint active state, swap on click, persist to localStorage.
        var current = document.documentElement.getAttribute('data-theme') || 'magazine';
        function paintActive(t) {
          document.querySelectorAll('[data-theme-set]').forEach(function (b) {
            var on = b.getAttribute('data-theme-set') === t;
            b.classList.toggle('active', on);
            b.setAttribute('aria-checked', on ? 'true' : 'false');
          });
        }
        paintActive(current);
        document.querySelectorAll('[data-theme-set]').forEach(function (b) {
          b.addEventListener('click', function () {
            var t = b.getAttribute('data-theme-set');
            document.documentElement.setAttribute('data-theme', t);
            try { localStorage.setItem('culoton-theme', t); } catch (_) {}
            paintActive(t);
          });
        });
      })();
    </script>

    <div class="ticker" aria-hidden="true">
      <div class="track">
        <span><span class="ticker-tag">$TON</span> tracking telegram-driven flows</span>
        <span><span class="ticker-tag">$CULO</span> native token of the desk</span>
        <span>edited by <span class="ticker-tag">CuloScribe</span> AI</span>
        <span><span class="ticker-tag">desk</span> covers ton ecosystem 24/7</span>
        <span><span class="ticker-tag">$TON</span> tracking telegram-driven flows</span>
        <span><span class="ticker-tag">$CULO</span> native token of the desk</span>
        <span>edited by <span class="ticker-tag">CuloScribe</span> AI</span>
        <span><span class="ticker-tag">desk</span> covers ton ecosystem 24/7</span>
      </div>
    </div>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="inner">
        <div>
          <span set:html={t.footer_tagline_html} />
          <div class="edited-by">
            <img src="/culoscribe.png" alt="CuloScribe AI" class="edited-by-avatar" />
            <span>{t.footer_edited_by}</span>
          </div>
        </div>
        <div>
          <a href={localizedPath(locale, '/blog')}>{t.nav_blog}</a>
          <a href={localizedPath(locale, '/pulse')}>{t.footer_pulse}</a>
          <a href={localizedPath(locale, '/about')}>{t.footer_about}</a>
          <a href={localizedPath(locale, '/culo')}>{t.footer_token}</a>
          <a href="https://t.me/culoton" target="_blank" rel="noopener noreferrer">{t.footer_telegram}</a>
          <a href="https://x.com/culoton_" target="_blank" rel="noopener noreferrer">{t.footer_x}</a>
          <a href="/rss.xml">{t.footer_rss}</a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  .masthead-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-mute);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-left: 6px;
    align-self: flex-end;
    padding-bottom: 4px;
  }
  .header-menu {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .hamburger {
    display: none;
    background: transparent;
    border: 1px solid var(--rule);
    border-radius: 0;
    padding: 8px 10px;
    cursor: pointer;
    flex-direction: column;
    gap: 4px;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
  }
  .hamburger span {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--text);
    transition: transform 0.18s, opacity 0.18s;
  }
  .site-header.menu-open .hamburger span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .site-header.menu-open .hamburger span:nth-child(2) {
    opacity: 0;
  }
  .site-header.menu-open .hamburger span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }
  .lang-switcher {
    display: flex;
    gap: 4px;
    align-items: center;
    margin-left: 16px;
    padding-left: 16px;
    border-left: 1px solid var(--rule-soft);
  }
  .lang-link {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    padding: 4px 7px;
    border-radius: 0;
    border: 1px solid transparent;
    color: var(--text-mute) !important;
    text-decoration: none;
    transition: color 0.12s, background 0.12s;
  }
  .lang-link:hover {
    color: var(--text) !important;
  }
  .lang-link.active {
    background: var(--text);
    color: var(--accent) !important;
  }
  .theme-switcher {
    display: none;
    gap: 2px;
    align-items: center;
    margin-left: 14px;
    padding-left: 14px;
    border-left: 1px solid var(--rule-soft);
  }
  .theme-switcher button {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 4px 8px;
    border-radius: 0;
    border: 1px solid var(--rule-soft);
    background: transparent;
    color: var(--text-mute);
    cursor: pointer;
    line-height: 1;
    transition: color 0.12s, background 0.12s, border-color 0.12s;
  }
  .theme-switcher button:hover {
    color: var(--text);
    border-color: var(--text-dim);
  }
  .theme-switcher button.active {
    background: var(--accent);
    color: #1a1408;
    border-color: var(--accent);
  }
  @media (max-width: 720px) {
    .header-menu .theme-switcher {
      margin-top: 10px;
      margin-left: 0;
      padding-left: 0;
      border-left: none;
    }
    .theme-switcher button { padding: 6px 10px; font-size: 12px; }
  }
  .edited-by {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 10px;
    font-size: 12px;
    color: var(--text-mute);
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
  }
  .edited-by-avatar {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--rule);
  }
  @media (max-width: 720px) {
    .masthead-tag { display: none; }
    .hamburger { display: flex; }
    .header-menu {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: var(--bg);
      border-bottom: 2px solid var(--rule);
      padding: 8px 20px 16px;
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      pointer-events: none;
      transition: max-height 0.22s ease, opacity 0.18s ease, padding 0.22s ease;
    }
    .site-header.menu-open .header-menu {
      max-height: 360px;
      opacity: 1;
      pointer-events: auto;
      padding: 12px 20px 18px;
    }
    .header-menu nav.main-nav {
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .header-menu nav.main-nav a {
      display: block;
      margin-left: 0;
      padding: 14px 4px;
      font-size: 14px;
      border-bottom: 1px solid var(--rule-soft);
    }
    .header-menu nav.main-nav a:last-child {
      border-bottom: none;
    }
    .header-menu .lang-switcher {
      margin-top: 14px;
      margin-left: 0;
      padding-left: 0;
      border-left: none;
      justify-content: flex-start;
      flex-wrap: wrap;
    }
    .header-menu .lang-link {
      padding: 8px 12px;
      font-size: 12px;
      border: 1px solid var(--rule-soft);
    }
  }
</style>
