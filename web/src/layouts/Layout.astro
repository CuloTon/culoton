---
import '../styles/global.css';
import '../styles/editorial.css';
import { UI, LOCALES, LOCALE_LABELS, LOCALE_FULL, HTML_LANG, localizedPath, type Locale } from '../i18n/strings';
import LaunchBanner from '../components/LaunchBanner.astro';

interface Props {
  locale: Locale;
  title?: string;
  description?: string;
  ogImage?: string;
  /** Path of the current page WITHOUT the locale prefix, e.g. '/' or '/about' or '/news/foo'. */
  pathWithoutLocale: string;
}

const {
  locale,
  title,
  description,
  ogImage = '/brainrot.png',
  pathWithoutLocale,
} = Astro.props;

const t = UI[locale];
const finalTitle = title ?? t.site_title;
const finalDescription = description ?? t.site_description;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const STATS_API = (import.meta.env.PUBLIC_STATS_API ?? '').toString().replace(/\/$/, '');

const alternates = LOCALES.map((loc) => ({
  loc,
  href: new URL(localizedPath(loc, pathWithoutLocale), Astro.site).toString(),
}));
---

<!doctype html>
<html lang={HTML_LANG[locale]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/brainrot.png?v=2" />
    <link rel="apple-touch-icon" href="/brainrot.png?v=2" />
    <link rel="canonical" href={canonical} />
    {STATS_API && <meta name="stats-api" content={STATS_API} />}

    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.loc} href={a.href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={alternates[0].href} />

    <title>{finalTitle}</title>
    <meta name="description" content={finalDescription} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={finalTitle} />
    <meta property="og:description" content={finalDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
    <meta property="og:locale" content={locale === 'en' ? 'en_US' : `${locale}_${locale.toUpperCase()}`} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={finalTitle} />
    <meta name="twitter:description" content={finalDescription} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />

    <script src="https://analytics.ahrefs.com/analytics.js" data-key="VDA3wFbsw802PgWchdD3tw" async></script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Serif:ital,wght@0,400;0,600;0,700;0,800;1,400;1,700&family=IBM+Plex+Mono:wght@400;500;600;700&family=Archivo+Black&family=Space+Grotesk:wght@400;500;700&family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400;1,700&display=swap"
    />

    <script is:inline>
      // Editorial Noir is the only theme. Force it on every visit and clear any
      // stale localStorage flag from legacy theme experiments.
      document.documentElement.setAttribute('data-theme', 'editorial');
      try {
        localStorage.setItem('brainrot-theme', 'editorial');
        localStorage.setItem('culoton-theme', 'editorial');
      } catch (_) {}
    </script>
    <script is:inline>
      (function () {
        var meta = document.querySelector('meta[name="stats-api"]');
        if (!meta) return;
        var api = (meta.getAttribute('content') || '').replace(/\/$/, '');
        if (!api) return;

        function sid() {
          try {
            var s = sessionStorage.getItem('culoton-sid');
            if (s) return s;
            var arr = new Uint8Array(12);
            (window.crypto || window.msCrypto).getRandomValues(arr);
            s = Array.from(arr, function (b) { return ('0' + b.toString(16)).slice(-2); }).join('');
            sessionStorage.setItem('culoton-sid', s);
            return s;
          } catch (_) { return null; }
        }
        var id = sid();
        if (!id) return;

        function visit() {
          try {
            fetch(api + '/visit', { method: 'POST', keepalive: true, credentials: 'omit' });
          } catch (_) {}
        }
        function beat() {
          if (document.hidden) return;
          try {
            fetch(api + '/heartbeat?sid=' + encodeURIComponent(id), {
              method: 'POST', keepalive: true, credentials: 'omit'
            });
          } catch (_) {}
        }
        // One pageview, then keep heartbeating while the tab is open.
        visit();
        beat();
        setInterval(beat, 25000);
        document.addEventListener('visibilitychange', function () { if (!document.hidden) beat(); });
      })();
    </script>
  </head>
  <body>
    <header class="site-header" id="site-header">
      <div class="inner">
        <a href={locale === 'en' ? '/home' : localizedPath(locale, '/')} class="logo">
          <img src="/brainrot.png" alt="BRAINROT logo" />
          <div>
            <span class="brand-culo">BRAIN</span><span class="brand-ton">ROT</span>
          </div>
          <span class="masthead-tag">— TON Desk · $BRT</span>
        </a>

        <nav class="primary-nav-desktop" aria-label="Primary">
          <a href={localizedPath(locale, '/')}>{t.nav_news}</a>
          <a href={localizedPath(locale, '/community')}>{t.nav_blog}</a>
          <a href={localizedPath(locale, '/ecosystem')}>{t.nav_ecosystem}</a>
          <a href={localizedPath(locale, '/launch')} class="primary-launch">{t.nav_launch}</a>
          <a href={localizedPath(locale, '/tokens')}>{t.nav_tokens}</a>
          <a href={localizedPath(locale, '/token')}>{t.nav_board}</a>
          <a href={localizedPath(locale, '/rewards')}>{t.nav_rewards}</a>
          <a href={localizedPath(locale, '/culo')} class="primary-token">{t.nav_token}</a>
        </nav>

        <div class="lang-switcher-top" aria-label="Language">
          {LOCALES.map((loc) => (
            <a
              href={localizedPath(loc, pathWithoutLocale)}
              class:list={["lang-link", { active: loc === locale }]}
              hreflang={loc}
              title={LOCALE_FULL[loc]}
            >{LOCALE_LABELS[loc]}</a>
          ))}
        </div>

        <button
          type="button"
          class="hamburger"
          aria-label="Toggle full menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
          id="hamburger-btn"
        >
          <span></span><span></span><span></span>
        </button>
        <div class="header-menu" id="mobile-menu">
          <nav class="main-nav">
            <a href={localizedPath(locale, '/')}>{t.nav_news}</a>
            <a href={localizedPath(locale, '/community')}>{t.nav_blog}</a>
            <a href={localizedPath(locale, '/tales')}>{t.nav_tales}</a>
            <a href={localizedPath(locale, '/archive')}>{t.nav_archive}</a>
            <a href={localizedPath(locale, '/ecosystem')}>{t.nav_ecosystem}</a>
            <a href={localizedPath(locale, '/mini-apps')}>{t.nav_apps}</a>
            <a href={localizedPath(locale, '/launch')} class="nav-launch">
              {t.nav_launch}
              <span class="nav-new-pill">{t.nav_launch_badge}</span>
            </a>
            <a href={localizedPath(locale, '/tokens')}>{t.nav_tokens}</a>
            <a href={localizedPath(locale, '/token')}>{t.nav_board}</a>
            <a href={localizedPath(locale, '/rewards')}>{t.nav_rewards}</a>
            <a href={localizedPath(locale, '/about')}>{t.nav_about}</a>
            <a href={localizedPath(locale, '/stonks')}>{t.nav_stonks}</a>
            <a href={localizedPath(locale, '/culo')}>{t.nav_token}</a>
          </nav>
          <div class="lang-switcher" aria-label="Language">
            {LOCALES.map((loc) => (
              <a
                href={localizedPath(loc, pathWithoutLocale)}
                class:list={["lang-link", { active: loc === locale }]}
                hreflang={loc}
                title={LOCALE_FULL[loc]}
              >{LOCALE_LABELS[loc]}</a>
            ))}
          </div>
        </div>
      </div>
    </header>
    <script is:inline>
      (function () {
        var btn = document.getElementById('hamburger-btn');
        var hdr = document.getElementById('site-header');
        if (btn && hdr) {
          btn.addEventListener('click', function () {
            var open = hdr.classList.toggle('menu-open');
            btn.setAttribute('aria-expanded', open ? 'true' : 'false');
          });
          document.querySelectorAll('#mobile-menu a').forEach(function (a) {
            a.addEventListener('click', function () {
              hdr.classList.remove('menu-open');
              btn.setAttribute('aria-expanded', 'false');
            });
          });
        }

      })();
    </script>

    <div class="ticker" aria-hidden="true">
      <div class="track">
        <span><span class="ticker-tag">$BRT</span> brainrot economy on TON</span>
        <span>formerly known as <span class="ticker-tag">CuloTon</span> — same team, fresh bag</span>
        <span><span class="ticker-tag">$TON</span> tracking telegram-driven flows</span>
        <span>edited by <span class="ticker-tag">BrainScribe</span> AI</span>
        <span>stay brainrotted · more brt in the bag</span>
        <span><span class="ticker-tag">$BRT</span> brainrot economy on TON</span>
        <span>formerly known as <span class="ticker-tag">CuloTon</span> — same team, fresh bag</span>
        <span><span class="ticker-tag">$TON</span> tracking telegram-driven flows</span>
        <span>edited by <span class="ticker-tag">BrainScribe</span> AI</span>
        <span>stay brainrotted · more brt in the bag</span>
      </div>
    </div>

    <LaunchBanner locale={locale} />

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="inner">
        <div>
          <span set:html={t.footer_tagline_html} />
          <div class="edited-by">
            <img src="/brainscribe.svg" alt="BrainScribe AI" class="edited-by-avatar" />
            <span>{t.footer_edited_by}</span>
          </div>
        </div>
        <div>
          <a href={localizedPath(locale, '/community')}>{t.nav_blog}</a>
          <a href={localizedPath(locale, '/about')}>{t.footer_about}</a>
          <a href={localizedPath(locale, '/culo')}>{t.footer_token}</a>
          <a href="https://t.me/culoton" target="_blank" rel="noopener noreferrer">{t.footer_telegram}</a>
          <a href="https://x.com/culoton_" target="_blank" rel="noopener noreferrer">{t.footer_x}</a>
          <a href="https://github.com/CuloTon/culoton" target="_blank" rel="noopener noreferrer">{t.footer_github}</a>
          <a href="/rss.xml">{t.footer_rss}</a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style>
  .nav-launch {
    position: relative;
    display: inline-flex !important;
    align-items: center;
    gap: 6px;
  }
  .nav-new-pill {
    display: inline-block;
    background: var(--accent, #f0b400);
    color: #1a1408;
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.1em;
    padding: 2px 5px;
    border-radius: 2px;
    line-height: 1;
    animation: navpulse 1.8s ease-in-out infinite;
  }
  @keyframes navpulse {
    0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(240, 180, 0, 0.55); }
    50% { transform: scale(1.05); box-shadow: 0 0 0 4px rgba(240, 180, 0, 0); }
  }
  .masthead-tag {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-mute);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-left: 6px;
    align-self: flex-end;
    padding-bottom: 4px;
  }
  /* === Primary nav — slim, always visible on desktop, hidden on mobile === */
  .primary-nav-desktop {
    display: flex;
    gap: 4px;
    align-items: center;
    margin-left: auto;
    margin-right: 12px;
  }
  .primary-nav-desktop a {
    font-family: "Inter", system-ui, sans-serif;
    font-weight: 600;
    font-size: 14px;
    color: var(--text-dim, #2d3142);
    padding: 9px 14px;
    border-radius: 999px;
    text-decoration: none;
    transition: background 0.18s, color 0.18s, transform 0.18s;
  }
  .primary-nav-desktop a:hover {
    background: rgba(255, 111, 111, 0.10);
    color: var(--accent-text, #d63838);
    transform: translateY(-1px);
  }
  .primary-nav-desktop a.primary-token {
    background: linear-gradient(135deg, #ff6f6f 0%, #b8a5ff 100%);
    color: #fff !important;
    font-weight: 700;
  }
  .primary-nav-desktop a.primary-token:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 22px rgba(255, 111, 111, 0.30);
  }
  @media (max-width: 720px) {
    .primary-nav-desktop { display: none; }
  }

  /* === Full menu drawer — opens on hamburger click on ALL viewports === */
  .header-menu {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: rgba(253, 251, 247, 0.96);
    backdrop-filter: saturate(160%) blur(18px);
    -webkit-backdrop-filter: saturate(160%) blur(18px);
    border-bottom: 1px solid var(--rule, rgba(20, 20, 30, 0.08));
    box-shadow: 0 20px 60px rgba(20, 20, 30, 0.10);
    padding: 16px 28px 24px;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 6px;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    transition: max-height 0.22s ease, opacity 0.18s ease, padding 0.22s ease;
  }
  .site-header.menu-open .header-menu {
    max-height: calc(100vh - 80px);
    overflow-y: auto;
    opacity: 1;
    pointer-events: auto;
    padding: 18px 28px 28px;
  }

  /* === Hamburger — always visible (desktop + mobile) === */
  .hamburger {
    display: flex;
    background: transparent;
    border: 1px solid var(--rule, rgba(20, 20, 30, 0.10));
    border-radius: 12px;
    padding: 8px 10px;
    cursor: pointer;
    flex-direction: column;
    gap: 4px;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    transition: background 0.18s, border-color 0.18s;
  }
  .hamburger:hover {
    background: rgba(255, 111, 111, 0.08);
    border-color: rgba(255, 111, 111, 0.30);
  }
  .hamburger span {
    display: block;
    width: 18px;
    height: 2px;
    background: var(--text);
    transition: transform 0.18s, opacity 0.18s;
  }
  .site-header.menu-open .hamburger span:nth-child(1) {
    transform: translateY(6px) rotate(45deg);
  }
  .site-header.menu-open .hamburger span:nth-child(2) {
    opacity: 0;
  }
  .site-header.menu-open .hamburger span:nth-child(3) {
    transform: translateY(-6px) rotate(-45deg);
  }
  /* Drawer language switcher — hidden; languages now live in the top bar
     (.lang-switcher-top) on every viewport, desktop included. */
  .lang-switcher {
    display: none;
    gap: 4px;
    align-items: center;
    margin-left: 16px;
    padding-left: 16px;
    border-left: 1px solid var(--rule-soft);
  }
  /* Top-bar language switcher — top bar on desktop AND mobile. */
  .lang-switcher-top {
    display: flex;
    align-items: center;
    gap: 3px;
    margin-left: auto;
    margin-right: 8px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .lang-switcher-top .lang-link {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.04em;
    padding: 4px 6px;
    border-radius: 6px;
    border: 1px solid var(--rule-soft);
    color: var(--text-mute) !important;
    text-decoration: none;
    line-height: 1;
  }
  .lang-switcher-top .lang-link.active {
    background: var(--text);
    color: var(--accent) !important;
    border-color: var(--text);
  }
  .lang-link {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    padding: 4px 7px;
    border-radius: 0;
    border: 1px solid transparent;
    color: var(--text-mute) !important;
    text-decoration: none;
    transition: color 0.12s, background 0.12s;
  }
  .lang-link:hover {
    color: var(--text) !important;
  }
  .lang-link.active {
    background: var(--text);
    color: var(--accent) !important;
  }
  .theme-switcher {
    display: none;
    gap: 2px;
    align-items: center;
    margin-left: 14px;
    padding-left: 14px;
    border-left: 1px solid var(--rule-soft);
  }
  .theme-switcher button {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.06em;
    padding: 4px 8px;
    border-radius: 0;
    border: 1px solid var(--rule-soft);
    background: transparent;
    color: var(--text-mute);
    cursor: pointer;
    line-height: 1;
    transition: color 0.12s, background 0.12s, border-color 0.12s;
  }
  .theme-switcher button:hover {
    color: var(--text);
    border-color: var(--text-dim);
  }
  .theme-switcher button.active {
    background: var(--accent);
    color: #1a1408;
    border-color: var(--accent);
  }
  @media (max-width: 720px) {
    .header-menu .theme-switcher {
      margin-top: 10px;
      margin-left: 0;
      padding-left: 0;
      border-left: none;
    }
    .theme-switcher button { padding: 6px 10px; font-size: 12px; }
  }
  .edited-by {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 10px;
    font-size: 12px;
    color: var(--text-mute);
    font-family: var(--font-mono);
    letter-spacing: 0.04em;
  }
  .edited-by-avatar {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid var(--rule);
  }
  /* Drawer nav items — column always (since drawer opens on desktop too) */
  .header-menu nav.main-nav {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .header-menu nav.main-nav a {
    display: block;
    margin-left: 0;
    padding: 14px 6px;
    font-size: 15px;
    border-bottom: 1px solid var(--rule-soft, rgba(20, 20, 30, 0.04));
    text-decoration: none;
    color: var(--text-dim, #2d3142);
    transition: color 0.15s, padding-left 0.15s;
  }
  .header-menu nav.main-nav a:hover {
    color: var(--accent-text, #d63838);
    padding-left: 12px;
  }
  .header-menu nav.main-nav a:last-child {
    border-bottom: none;
  }

  /* === Desktop drawer — button-card grid (≥721px) === */
  @media (min-width: 721px) {
    .header-menu {
      padding: 22px 28px 26px;
    }
    .site-header.menu-open .header-menu {
      padding: 24px 28px 30px;
    }
    /* Constrain the inner drawer content so it doesn't stretch edge-to-edge
       on wide viewports — keeps everything visually grouped as a panel. */
    .header-menu nav.main-nav,
    .header-menu > .lang-switcher,
    .header-menu > .theme-switcher,
    .header-menu > .edited-by {
      width: 100%;
      max-width: 960px;
      margin-left: auto;
      margin-right: auto;
    }
    .header-menu nav.main-nav {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 12px;
    }
    .header-menu nav.main-nav a {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 16px 18px;
      border: 1px solid var(--rule, rgba(20, 20, 30, 0.10));
      border-radius: 14px;
      background: rgba(255, 255, 255, 0.62);
      font-size: 15px;
      font-weight: 700;
      letter-spacing: 0.01em;
      color: var(--text, #1a1612);
      text-align: center;
      box-shadow: 0 4px 14px rgba(20, 20, 30, 0.05);
      transition: transform 0.16s ease, box-shadow 0.16s ease,
                  border-color 0.16s ease, background 0.16s ease,
                  color 0.16s ease;
    }
    .header-menu nav.main-nav a:hover {
      transform: translateY(-2px);
      background: rgba(255, 255, 255, 0.92);
      border-color: rgba(255, 111, 111, 0.45);
      color: var(--accent-text, #d63838);
      box-shadow: 0 10px 22px rgba(255, 111, 111, 0.18);
      padding-left: 18px; /* neutralise the mobile slide-in hover */
    }
    .header-menu nav.main-nav a.nav-launch {
      background: linear-gradient(135deg,
                  rgba(255, 230, 0, 0.30),
                  rgba(255, 111, 111, 0.22));
      border-color: rgba(255, 111, 111, 0.40);
    }
    .header-menu nav.main-nav a.nav-launch:hover {
      background: linear-gradient(135deg,
                  rgba(255, 230, 0, 0.55),
                  rgba(255, 111, 111, 0.38));
    }
    /* $BRT token tile — make it the standout button */
    .header-menu nav.main-nav a:last-child {
      background: linear-gradient(135deg, #ff6f6f 0%, #b8a5ff 100%);
      border-color: transparent;
      color: #fff;
      box-shadow: 0 6px 18px rgba(255, 111, 111, 0.30);
    }
    .header-menu nav.main-nav a:last-child:hover {
      transform: translateY(-3px);
      color: #fff;
      box-shadow: 0 12px 26px rgba(255, 111, 111, 0.38);
    }
    /* Lang switcher: pill row centered under the grid */
    .header-menu > .lang-switcher {
      margin-top: 18px;
      margin-left: auto;
      padding-left: 0;
      border-left: none;
      justify-content: center;
      gap: 6px;
      flex-wrap: wrap;
    }
    .header-menu .lang-link {
      padding: 7px 12px;
      font-size: 12px;
      border: 1px solid var(--rule, rgba(20, 20, 30, 0.10));
      border-radius: 999px;
    }
    /* Theme switcher (currently display:none, kept hidden) — but if re-enabled,
       center it under the lang row to match. */
    .header-menu > .theme-switcher {
      margin-top: 12px;
      margin-left: auto;
      padding-left: 0;
      border-left: none;
      justify-content: center;
    }
  }
  @media (min-width: 721px) and (max-width: 900px) {
    .header-menu nav.main-nav {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 720px) {
    .masthead-tag { display: none; }
    /* Lang switcher moves up to the top bar (next to BRAINROT); hide the
       duplicate inside the drawer. */
    .lang-switcher-top { display: flex; }
