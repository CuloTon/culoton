---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'CuloTon — TON Blockchain News',
  description = 'Daily news, analysis and updates from the TON blockchain ecosystem. Powered by $CULO.',
  ogImage = '/culo.png',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />
  </head>
  <body>
    <header class="site-header">
      <div class="inner">
        <a href="/" class="logo">
          <img src="/culo.png" alt="CuloTon logo" />
          <div>
            <span class="brand-culo">Culo</span><span class="brand-ton">Ton</span>
          </div>
        </a>
        <nav class="main-nav">
          <a href="/">News</a>
          <a href="/about">About</a>
          <a href="/culo">$CULO</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="inner">
        <div>
          <strong>CuloTon</strong> — TON ecosystem news, powered by <span style="color: var(--accent); font-family: var(--font-mono);">$CULO</span>
        </div>
        <div>
          <a href="/about">About</a>
          <a href="/culo">$CULO</a>
          <a href="https://t.me/culoton" target="_blank" rel="noopener noreferrer">Telegram</a>
          <a href="/rss.xml">RSS</a>
        </div>
      </div>
    </footer>
  </body>
</html>
