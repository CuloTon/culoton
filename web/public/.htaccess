# BRAINROT preview gate (rebrand 2026-05-26)
# Public sees /index.html (maintenance page). Everything else needs Basic Auth.

AuthType Basic
AuthName "BRAINROT preview — enter password to see the new site"
# Seohost.pl is DirectAdmin — per-domain public_html lives under /home/<user>/domains/<domain>/public_html/.
AuthUserFile /home/srv96450/domains/culoton.fun/public_html/.htpasswd

# Mark public-accessible URIs (root maintenance + assets it loads)
SetEnvIf Request_URI "^/$"               public_uri=1
SetEnvIf Request_URI "^/index\.html$"    public_uri=1
SetEnvIf Request_URI "^/brainrot\.png$"  public_uri=1
SetEnvIf Request_URI "^/favicon\.png$"   public_uri=1
SetEnvIf Request_URI "^/favicon\.ico$"   public_uri=1
SetEnvIf Request_URI "^/robots\.txt$"    public_uri=1

<RequireAny>
    Require env public_uri
    Require valid-user
</RequireAny>

# Belt-and-braces: never expose .ht* files
<FilesMatch "^\.ht">
    Require all denied
</FilesMatch>

# Tell search engines to back off during rebrand
Header set X-Robots-Tag "noindex, nofollow"
